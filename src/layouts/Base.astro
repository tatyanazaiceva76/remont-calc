          <a href="https://moskva.kalkremont.ru/">Москва</a>
          <a href="https://spb.kalkremont.ru/">СПб</a>
          <a href="https://ekb.kalkremont.ru/">Екатеринбург</a>
          <a href="https://kzn.kalkremont.ru/">Казань</a>
          <a href="https://nsk.kalkremont.ru/">Новосибирск</a>
          <a href="https://nn.kalkremont.ru/">Н. Новгород</a>
          <a href="https://krd.kalkremont.ru/">Краснодар</a>
        </div>
        <div class="footer-network">
          <strong>Города:</strong>
          <a href="https://chel.kalkremont.ru/">Челябинск</a>
          <a href="https://ufa.kalkremont.ru/">Уфа</a>
          <a href="https://sam.kalkremont.ru/">Самара</a>
          <a href="https://rnd.kalkremont.ru/">Ростов-на-Дону</a>
          <a href="https://vrn.kalkremont.ru/">Воронеж</a>
          <a href="https://perm.kalkremont.ru/">Пермь</a>
          <a href="https://vlg.kalkremont.ru/">Волгоград</a>
        </div>

        <nav class="footer-nav">
          <a href="/o-sayte/">О проекте</a>
          <a href="/politika/">Политика конфиденциальности</a>
          <a href="/karta-sayta/">Карта сайта</a>
          <a href="/sitemap.xml">XML Sitemap</a>
        </nav>
        <p>© {new Date().getFullYear()} {SITE_CONFIG.siteName}. Калькуляторы носят справочный характер.</p>
      </div>
    </footer>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #1a1a1a;
        background: #fff;
      }
      h1, h2, h3 { line-height: 1.25; margin: 0 0 16px; }
      h1 { font-size: 28px; }
      h2 { font-size: 22px; margin-top: 32px; }
      h3 { font-size: 18px; margin-top: 24px; }
      p { margin: 0 0 12px; }
      a { color: #0a5cce; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .container { max-width: 760px; margin: 0 auto; padding: 0 16px; }
      .site-header {
        background: #f7f8fa;
        border-bottom: 1px solid #e6e8eb;
        padding: 14px 0;
      }
      .site-header .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }
      .logo { font-weight: 700; color: #1a1a1a; font-size: 16px; }
      .nav { display: flex; gap: 16px; font-size: 14px; flex-wrap: wrap; }
      .nav a { color: #555; }
      .nav-disabled { color: #aaa; }
      .nav-highlight {
        background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
        color: #fff !important;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
      }
      .nav-highlight:hover { text-decoration: none; opacity: 0.9; }
      main { padding: 24px 16px 48px; }
      .site-footer {
        background: #f7f8fa;
        border-top: 1px solid #e6e8eb;
        padding: 20px 0;
        font-size: 13px;
        color: #666;
        margin-top: 48px;
      }
      .footer-nav { display: flex; gap: 18px; flex-wrap: wrap; margin: 16px 0 10px; padding-top: 14px; border-top: 1px solid #e6e8eb; }
      .footer-nav a { color: #666; }
      .footer-network {
        margin: 18px 0 6px;
        padding: 12px 14px;
        background: #fff7e6;
        border: 1px solid #f5d3a3;
        border-radius: 6px;
        font-size: 13px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
      }
      .footer-network strong { color: #333; }
      .footer-network a { color: #0a5cce; }
      .footer-mega {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 24px;
        margin-bottom: 8px;
      }
      .footer-col h4 {
        font-size: 13px;
        margin: 0 0 8px;
        color: #333;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }
      .footer-col ul { list-style: none; padding: 0; margin: 0; }
      .footer-col li { margin-bottom: 4px; font-size: 13px; }
      .footer-col a { color: #666; }
      .footer-col a:hover { color: #0a5cce; }
      @media (max-width: 720px) {
        .footer-mega { grid-template-columns: 1fr 1fr 1fr; }
      }
      @media (max-width: 540px) {
        .footer-mega { grid-template-columns: 1fr 1fr; }
      }
    </style>
  </body>
</html>
