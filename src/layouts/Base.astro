---
import { SITE_CONFIG } from '~/config';
import Metrika from '~/components/Metrika.astro';
import StickyCta from '~/components/StickyCta.astro';
// ExitIntent временно отключён — заменяем на нормальную лид-форму (не WhatsApp redirect)
// import ExitIntent from '~/components/ExitIntent.astro';
import TopBanner from '~/components/TopBanner.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  noindex?: boolean;
  /** Доп. schema объект для конкретной страницы (Article, FAQPage и т.д.) */
  extraSchema?: object;
  /** Аггрегированный рейтинг для калькулятора/продукта */
  rating?: { value: number; count: number };
  /** Дата последнего обновления страницы (ISO) */
  modified?: string;
}

const {
  title, description, canonical, schema, noindex = false,
  extraSchema, rating, modified
} = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const lastMod = modified || new Date().toISOString().slice(0, 10);

// Дефолтный WebPage schema на каждую страницу
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: canonicalUrl,
  inLanguage: 'ru-RU',
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.siteName,
    url: `https://${SITE_CONFIG.domain}/`
  },
  dateModified: lastMod,
  ...(rating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: rating.value,
      reviewCount: rating.count,
      bestRating: 5,
      worstRating: 1
    }
  } : {})
};
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta name="yandex-verification" content="460ea36bfc80a84e" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_CONFIG.siteName} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content="https://www.kalkremont.ru/og.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.kalkremont.ru/og/main.svg" />
    <meta name="twitter:site" content="@kalkremont" />

    <link rel="alternate" type="application/rss+xml" title="RSS — новые материалы" href="https://www.kalkremont.ru/feed.rss" />
    <link rel="alternate" type="application/rss+xml" title="Turbo-страницы Яндекс" href="https://www.kalkremont.ru/turbo.xml" />
    <link rel="preconnect" href="https://mc.yandex.ru" />
    <link rel="preconnect" href="https://yandex.ru" />

    {SITE_CONFIG.rsya.enabled && (
      <script is:inline async src="https://yandex.ru/ads/system/context.js"></script>
    )}

    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    {extraSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />
    )}

    <Metrika />
  </head>
  <body>
    <TopBanner />
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">{SITE_CONFIG.siteName}</a>
        <nav class="nav">
          <a href="/raschet-oboev/">Обои</a>
          <a href="/raschet-laminata/">Ламинат</a>
          <a href="/raschet-kraski/">Краска</a>
          <a href="/raschet-plitki/">Плитка</a>
          <a href="/raschet-shtukaturki/">Штукатурка</a>
          <a href="/raschet-linoleuma/">Линолеум</a>
          <a href="/raschet-gipsokartona/">ГКЛ</a>
          <a href="/raschet-uteplitelya/">Утеплитель</a>
          <a href="/raschet-betona/">Бетон</a>
          <a href="/raschet-krovli/">Кровля</a>
          <a href="/poisk/">🔍 Поиск</a>
          <a href="/sovety/">Советы</a>
          <a href="/chto-luchshe/">Что лучше</a>
          <a href="/brand/">Бренды</a>
          <a href="/stoimost-remonta/" class="nav-highlight">Стоимость ремонта 💰</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <StickyCta />
    <!-- ExitIntent временно отключён -->
    <!-- <ExitIntent /> -->

    <footer class="site-footer">
      <div class="container">
        <div class="footer-mega">
          <div class="footer-col">
            <h4>Отделка</h4>
            <ul>
              <li><a href="/raschet-oboev/">Обои</a></li>
              <li><a href="/raschet-kraski/">Краска</a></li>
              <li><a href="/raschet-shtukaturki/">Штукатурка</a></li>
              <li><a href="/raschet-plitki/">Плитка</a></li>
              <li><a href="/raschet-gruntovki/">Грунтовка</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Полы</h4>
            <ul>
              <li><a href="/raschet-laminata/">Ламинат</a></li>
              <li><a href="/raschet-linoleuma/">Линолеум</a></li>
              <li><a href="/raschet-plintusa/">Плинтус</a></li>
              <li><a href="/raschet-betona/styazhki-pola/">Стяжка пола</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Стройка</h4>
            <ul>
              <li><a href="/raschet-gipsokartona/">Гипсокартон</a></li>
              <li><a href="/raschet-uteplitelya/">Утеплитель</a></li>
              <li><a href="/raschet-betona/">Бетон</a></li>
              <li><a href="/raschet-krovli/">Кровля</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Ремонт квартиры</h4>
