---
import Base from '~/layouts/Base.astro';
import LinoleumCalc from '~/components/LinoleumCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { linoleumScenarios } from '~/data/linoleum-scenarios';
import { linoleumFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return linoleumScenarios.map((s) => ({ params: { slug: s.slug }, props: { scenario: s } }));
}
const { scenario } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт линолеума', item: `https://${SITE_CONFIG.domain}/raschet-linoleuma/` },
    { '@type': 'ListItem', position: 3, name: scenario.h1, item: url }
  ]
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs] };
const related = linoleumScenarios.filter((s) => s.slug !== scenario.slug).slice(0, 10);
---
<Base title={scenario.title} description={scenario.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/raschet-linoleuma/">Расчёт линолеума</a><span>›</span>
    <span>{scenario.h1}</span>
  </nav>
  <h1>{scenario.h1}</h1>
  {scenario.introBlocks[0] && <p>{scenario.introBlocks[0]}</p>}

  <LinoleumCalc prefill={scenario.prefill} lock={scenario.lock} />
  <Rsya slot="top" />

  {scenario.introBlocks.slice(1).map((b) => <p>{b}</p>)}

  <h2>Что важно учесть</h2>
  <ul>
    <li><strong>Одним куском.</strong> Лучшая укладка — без швов. Берите рулон шире короткой стороны комнаты.</li>
    <li><strong>Подложка.</strong> Под бытовой линолеум — пробковая или вспененная (3-5 мм). Под коммерческий не нужна.</li>
    <li><strong>Климатическая выдержка.</strong> Перед укладкой линолеум должен полежать в комнате 24-48 часов в развёрнутом виде — выпрямится, примет температуру.</li>
    <li><strong>Плинтус.</strong> Линолеум кладётся с зазором 5-10 мм от стен, потом закрывается плинтусом.</li>
  </ul>

  <Faq items={linoleumFAQs} />
  <Rsya slot="bottom" />

  <section class="related">
    <h2>Похожие расчёты</h2>
    <ul class="related-list">
      {related.map((s) => <li><a href={`/raschet-linoleuma/${s.slug}/`}>{s.h1}</a></li>)}
    </ul>
  </section>
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ul { padding-left: 20px; } ul li { margin-bottom: 8px; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .related-list { grid-template-columns: 1fr; } }
</style>
