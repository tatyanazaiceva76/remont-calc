---
import Base from '~/layouts/Base.astro';
import LinoleumCalc from '~/components/LinoleumCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { linoleumByCategory } from '~/data/linoleum-scenarios';
import { linoleumFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор линолеума онлайн — расчёт без швов';
const description = 'Точный онлайн-калькулятор линолеума. Подбираем ширину рулона для укладки одним куском.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт линолеума', item: url }
  ]
};
const cats: Record<string, string> = {
  area: 'По площади комнаты',
  'room-type': 'По типу комнаты',
  'roll-width': 'По ширине рулона'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Расчёт линолеума</span></nav>
  <h1>Калькулятор линолеума онлайн</h1>
  <p>Введите размеры комнаты — калькулятор подскажет какой рулон купить, чтобы линолеум лёг одним куском без швов.</p>

  <LinoleumCalc />
  <Rsya slot="top" />

  <h2>Готовые расчёты</h2>
  {Object.entries(linoleumByCategory).map(([cat, list]) => (
    <section>
      <h3>{cats[cat]}</h3>
      <ul class="links">
        {list.map((s) => <li><a href={`/raschet-linoleuma/${s.slug}/`}>{s.h1}</a></li>)}
      </ul>
    </section>
  ))}

  <Faq items={linoleumFAQs} />
  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .links { list-style: none; padding: 0; margin: 12px 0 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; }
  .links a { display: block; padding: 6px 10px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; font-size: 14px; }
  .links a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .links { grid-template-columns: 1fr; } }
</style>
