---
import Base from '~/layouts/Base.astro';
import PaintCalc from '~/components/PaintCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { paintByCategory } from '~/data/paint-scenarios';
import { paintFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор краски онлайн — расчёт литров и фасовки';
const description = 'Точный калькулятор расчёта краски. Учитываем слои, расход, тип поверхности и подбираем оптимальную фасовку.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт краски', item: url }
  ]
};
const cats: Record<string, string> = {
  area: 'По площади комнаты',
  'room-type': 'По типу комнаты',
  'paint-type': 'По типу краски',
  surface: 'По поверхности и слоям'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Расчёт краски</span></nav>
  <h1>Калькулятор краски онлайн</h1>
  <p>Введите размеры комнаты, тип поверхности и количество слоёв — калькулятор подскажет нужный объём краски и оптимальную фасовку банок.</p>

  <PaintCalc />
  <Rsya slot="top" />

  <h2>Как пользоваться</h2>
  <ol>
    <li>Замерьте длину, ширину и высоту комнаты.</li>
    <li>Выберите что красите: стены, потолок или всё вместе.</li>
    <li>Укажите количество слоёв (обычно 2).</li>
    <li>Расход — на этикетке банки (обычно 8-14 м²/л).</li>
    <li>Укажите количество дверей и окон (стандарт: дверь 0,9 × 2,0 м, окно 1,5 × 1,4 м).</li>
    <li>Опционально — цена за литр для расчёта стоимости.</li>
  </ol>

  <h2>Готовые расчёты</h2>
  {Object.entries(paintByCategory).map(([cat, list]) => (
    <section>
      <h3>{cats[cat]}</h3>
      <ul class="links">
        {list.map((s) => <li><a href={`/raschet-kraski/${s.slug}/`}>{s.h1}</a></li>)}
      </ul>
    </section>
  ))}

  <Faq items={paintFAQs} />
  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ol { padding-left: 20px; } ol li { margin-bottom: 6px; }
  .links { list-style: none; padding: 0; margin: 12px 0 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; }
  .links a { display: block; padding: 6px 10px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; font-size: 14px; }
  .links a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .links { grid-template-columns: 1fr; } }
</style>
