---
import Base from '~/layouts/Base.astro';
import RoofCalc from '~/components/RoofCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import AffiliateLinks from '~/components/AffiliateLinks.astro';
import CalcLeadCTA from '~/components/CalcLeadCTA.astro';
import { roofScenarios } from '~/data/roof-scenarios';
import { roofFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return roofScenarios.map((s) => ({ params: { slug: s.slug }, props: { scenario: s } }));
}
const { scenario } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт кровли', item: `https://${SITE_CONFIG.domain}/raschet-krovli/` },
    { '@type': 'ListItem', position: 3, name: scenario.h1, item: url }
  ]
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs] };
const related = roofScenarios.filter((s) => s.slug !== scenario.slug).slice(0, 10);
---
<Base title={scenario.title} description={scenario.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/raschet-krovli/">Расчёт кровли</a><span>›</span>
    <span>{scenario.h1}</span>
  </nav>
  <h1>{scenario.h1}</h1>
  {scenario.introBlocks[0] && <p>{scenario.introBlocks[0]}</p>}

  <RoofCalc prefill={scenario.prefill} lock={scenario.lock} />
  <Rsya slot="top" />

  {scenario.introBlocks.slice(1).map((b) => <p>{b}</p>)}

  <h2>Что учитывается в расчёте</h2>
  <ul>
    <li><strong>Угол ската.</strong> Чем меньше угол, тем больше реальная площадь скатов по сравнению с проекцией.</li>
    <li><strong>Тип крыши.</strong> Двускатная — простой расчёт. Вальмовая — площадь больше на 5-10%. Односкатная — только один ската.</li>
    <li><strong>Запас на нахлёст.</strong> Зависит от материала: 8-15%. Без запаса не хватит на сложные участки.</li>
    <li><strong>Конёк, ендовы, торцы.</strong> Считаются отдельно, не входят в основной материал.</li>
  </ul>

  <Rsya slot="middle" />

  <CalcLeadCTA material="кровлю" source={`krovlya-${scenario.slug}`} />
  <AffiliateLinks material="plaster" />
  <Faq items={roofFAQs} />
  <Rsya slot="bottom" />

  <section class="related">
    <h2>Похожие расчёты</h2>
    <ul class="related-list">
      {related.map((s) => <li><a href={`/raschet-krovli/${s.slug}/`}>{s.h1}</a></li>)}
    </ul>
  </section>
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ul { padding-left: 20px; } ul li { margin-bottom: 8px; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .related-list { grid-template-columns: 1fr; } }
</style>
