---
import Base from '~/layouts/Base.astro';
import RoofCalc from '~/components/RoofCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { roofByCategory } from '~/data/roof-scenarios';
import { roofFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор кровли онлайн — расчёт материала, цена';
const description = 'Точный калькулятор кровли: металлочерепица, профнастил, мягкая кровля, ондулин. С учётом угла ската и типа крыши.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт кровли', item: url }
  ]
};
const cats: Record<string, string> = {
  area: 'По размеру дома',
  'roof-type': 'По типу крыши',
  material: 'По кровельному материалу'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Расчёт кровли</span></nav>
  <h1>Калькулятор кровли онлайн</h1>
  <p>Точный расчёт кровельного материала с учётом угла ската и типа крыши. Металлочерепица, профнастил, мягкая кровля, ондулин.</p>

  <RoofCalc />
  <Rsya slot="top" />

  <h2>Готовые расчёты</h2>
  {Object.entries(roofByCategory).map(([cat, list]) => (
    <section>
      <h3>{cats[cat]}</h3>
      <ul class="links">
        {list.map((s) => <li><a href={`/raschet-krovli/${s.slug}/`}>{s.h1}</a></li>)}
      </ul>
    </section>
  ))}

  <Faq items={roofFAQs} />
  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .links { list-style: none; padding: 0; margin: 12px 0 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; }
  .links a { display: block; padding: 6px 10px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; font-size: 14px; }
  .links a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .links { grid-template-columns: 1fr; } }
</style>
