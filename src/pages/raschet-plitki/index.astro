---
import Base from '~/layouts/Base.astro';
import TileCalc from '~/components/TileCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { tileByCategory } from '~/data/tile-scenarios';
import { tileFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор плитки онлайн — расчёт количества и стоимости';
const description = 'Точный онлайн-калькулятор расчёта плитки. Учитываем формат, шов и тип укладки.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт плитки', item: url }
  ]
};
const cats: Record<string, string> = {
  area: 'По площади',
  'room-type': 'По типу помещения',
  size: 'По формату плитки',
  layout: 'По типу укладки'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Расчёт плитки</span></nav>
  <h1>Калькулятор плитки онлайн</h1>
  <p>Введите площадь облицовки и размер плитки — калькулятор покажет нужное количество с учётом подрезки и шва.</p>

  <TileCalc />
  <Rsya slot="top" />

  <h2>Как пользоваться</h2>
  <ol>
    <li>Замерьте длину и ширину зоны облицовки в метрах.</li>
    <li>Укажите размер плитки в см (с этикетки на коробке).</li>
    <li>Выберите тип укладки: прямая (5%), со смещением (8%) или диагональная (15%).</li>
    <li>Уточните ширину шва (обычно 1,5-2 мм).</li>
    <li>Опционально — цена за м² для расчёта стоимости.</li>
  </ol>

  <h2>Готовые расчёты</h2>
  {Object.entries(tileByCategory).map(([cat, list]) => (
    <section>
      <h3>{cats[cat]}</h3>
      <ul class="links">
        {list.map((s) => <li><a href={`/raschet-plitki/${s.slug}/`}>{s.h1}</a></li>)}
      </ul>
    </section>
  ))}

  <Faq items={tileFAQs} />
  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ol { padding-left: 20px; } ol li { margin-bottom: 6px; }
  .links { list-style: none; padding: 0; margin: 12px 0 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 6px 14px; }
  .links a { display: block; padding: 6px 10px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; font-size: 14px; }
  .links a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .links { grid-template-columns: 1fr; } }
</style>
