---
import Base from '~/layouts/Base.astro';
import DrywallCalc from '~/components/DrywallCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import AffiliateLinks from '~/components/AffiliateLinks.astro';
import CalcLeadCTA from '~/components/CalcLeadCTA.astro';
import { drywallScenarios } from '~/data/drywall-scenarios';
import { drywallFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return drywallScenarios.map((s) => ({ params: { slug: s.slug }, props: { scenario: s } }));
}
const { scenario } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт гипсокартона', item: `https://${SITE_CONFIG.domain}/raschet-gipsokartona/` },
    { '@type': 'ListItem', position: 3, name: scenario.h1, item: url }
  ]
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs] };
const related = drywallScenarios.filter((s) => s.slug !== scenario.slug).slice(0, 10);
---
<Base title={scenario.title} description={scenario.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/raschet-gipsokartona/">Расчёт гипсокартона</a><span>›</span>
    <span>{scenario.h1}</span>
  </nav>
  <h1>{scenario.h1}</h1>
  {scenario.introBlocks[0] && <p>{scenario.introBlocks[0]}</p>}

  <DrywallCalc prefill={scenario.prefill} lock={scenario.lock} />
  <Rsya slot="top" />

  {scenario.introBlocks.slice(1).map((b) => <p>{b}</p>)}

  <h2>Какие материалы понадобятся</h2>
  <ul>
    <li><strong>Листы ГКЛ.</strong> Стандарт 2,5 × 1,2 м (3 м²). Для перегородок 12,5 мм, потолков — 9,5 мм.</li>
    <li><strong>Профиль UD (направляющий)</strong> — крепится по периметру горизонтально.</li>
    <li><strong>Профиль CD (стоечный)</strong> — вертикальные стойки с шагом 60 см.</li>
    <li><strong>Прямые подвесы</strong> — для крепления CD на потолке к перекрытию.</li>
    <li><strong>Саморезы по металлу</strong> 3,5×25 для крепления ГКЛ к профилю.</li>
    <li><strong>Шурупы LN для соединения профиля</strong> между собой.</li>
    <li><strong>Дюбели</strong> для крепления профиля к стенам/потолку.</li>
  </ul>

  <Rsya slot="middle" />

  <CalcLeadCTA material="гипсокартон" source={`gkl-${scenario.slug}`} />
  <AffiliateLinks material="plaster" />
  <Faq items={drywallFAQs} />
  <Rsya slot="bottom" />

  <section class="related">
    <h2>Похожие расчёты</h2>
    <ul class="related-list">
      {related.map((s) => <li><a href={`/raschet-gipsokartona/${s.slug}/`}>{s.h1}</a></li>)}
    </ul>
  </section>
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ul { padding-left: 20px; } ul li { margin-bottom: 8px; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .related-list { grid-template-columns: 1fr; } }
</style>
