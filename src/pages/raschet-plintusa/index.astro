---
import Base from '~/layouts/Base.astro';
import PlinthCalc from '~/components/PlinthCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import AffiliateLinks from '~/components/AffiliateLinks.astro';
import type { FAQ } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор плинтуса онлайн — расчёт планок';
const description = 'Точный расчёт плинтуса для комнаты: количество планок, угловые соединители, стоимость. С учётом дверей.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт плинтуса', item: url }
  ]
};

const faqs: FAQ[] = [
  { q: 'Какой плинтус выбрать?', a: 'Под ламинат — пластиковый ПВХ или МДФ (бюджет, стандарт высота 60-80 мм). Под паркет — деревянный (под цвет дерева пола, высота 50-80 мм). Под кафель — пластиковый или керамический.' },
  { q: 'Какая длина одной планки?', a: 'Стандарт ПВХ — 2,5 м. МДФ — 2,4 м. Деревянный — 2-3 м. Чем длиннее — тем меньше стыков на стене.' },
  { q: 'Сколько углов в типовой комнате?', a: 'В прямоугольной — 4 внутренних угла. Если есть эркер или ниши — больше. Внешние углы появляются вокруг колонн, выступов стен.' },
  { q: 'Чем крепить плинтус?', a: 'Пластиковый ПВХ — клипсы на стену + защёлкивается. МДФ — клей "жидкие гвозди" или саморезы в стену. Деревянный — гвозди или специальные крепления.' },
  { q: 'Можно ли стыковать планки в комнате?', a: 'Да, на длинной стене (>2,5 м) стык неизбежен. Делается под 45° или встык с соединителем. Стык желательно за мебелью, чтобы был менее заметен.' }
];
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Расчёт плинтуса</span></nav>

  <h1>Калькулятор плинтуса онлайн</h1>
  <p>Считаем сколько планок плинтуса нужно купить для комнаты с учётом дверных проёмов и длины планки.</p>

  <PlinthCalc />
  <Rsya slot="top" />

  <h2>Как пользоваться</h2>
  <ol>
    <li>Замерьте длину и ширину комнаты в метрах.</li>
    <li>Укажите количество дверей (стандартная ширина проёма 0,9 м вычитается из периметра).</li>
    <li>Выберите длину одной планки (зависит от материала).</li>
    <li>Опционально — впишите цену для расчёта стоимости.</li>
    <li>В результате — количество планок с запасом на запил углов + рекомендуемое количество угловых соединителей.</li>
  </ol>

  <h2>Типы плинтуса</h2>
  <ul>
    <li><strong>Пластиковый ПВХ</strong> (50-100 ₽/м). Самый дешёвый, легко монтируется, не боится воды. Минус — выглядит дёшево.</li>
    <li><strong>МДФ с покрытием</strong> (150-400 ₽/м). Под краску или с готовым покрытием (под дерево). Хорошее соотношение цена/качество.</li>
    <li><strong>Деревянный</strong> (300-1500 ₽/м). Натуральное дерево, премиум-вид. Дорого, требует обработки лаком/маслом.</li>
    <li><strong>Полиуретановый</strong> (200-500 ₽/м). Высокий (до 200 мм), под классические интерьеры. Можно красить.</li>
    <li><strong>Алюминиевый</strong> (400-800 ₽/м). Хай-тек, минимализм. Не стирается, не повреждается.</li>
  </ul>

  <Rsya slot="middle" />

  <h2>Расчёт по формуле</h2>
  <p>Количество планок = (Периметр комнаты − Ширина дверей) / Длина одной планки, округление вверх. Дополнительно +1 планка на угловые запилы.</p>
  <p>Для типовой комнаты 18 м² (5×4 м) с одной дверью: периметр 18 м − 0,9 м = 17,1 м. При длине планки 2,5 м нужно 7 планок + 1 на запас = 8 шт.</p>

  <AffiliateLinks material="laminate" />
  <Faq items={faqs} />
  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  ol { padding-left: 20px; } ol li { margin-bottom: 6px; }
  ul { padding-left: 20px; } ul li { margin-bottom: 8px; }
</style>
