---
import Base from '~/layouts/Base.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import AffiliateLinks from '~/components/AffiliateLinks.astro';
import { brandProducts } from '~/data/brand-products';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return brandProducts.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}
const { product } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Материалы по брендам', item: `https://${SITE_CONFIG.domain}/brand/` },
    { '@type': 'ListItem', position: 3, name: `${product.brand} ${product.product}`, item: url }
  ]
};

const productSchema = {
  '@context': 'https://schema.org', '@type': 'Product',
  name: `${product.brand} ${product.product}`,
  brand: { '@type': 'Brand', name: product.brand },
  description: product.description,
  category: 'Building Materials'
};

const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs, productSchema] };

// Карта category → material для аффилиатки
const matMap: Record<string, 'wallpaper' | 'laminate' | 'paint' | 'tile' | 'plaster' | 'linoleum'> = {
  plaster: 'plaster', 'tile-glue': 'tile', putty: 'plaster',
  paint: 'paint', primer: 'plaster', 'self-leveling': 'plaster',
  laminate: 'laminate'
};
const affMaterial = matMap[product.category] || 'plaster';

const related = brandProducts.filter((p) => p.slug !== product.slug && p.category === product.category).slice(0, 6);
---
<Base title={product.title} description={product.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/brand/">Материалы по брендам</a><span>›</span>
    <span>{product.brand} {product.product}</span>
  </nav>

  <h1>{product.h1}</h1>
  <p class="lead">{product.intro}</p>

  <Rsya slot="top" />

  <h2>Технические характеристики</h2>
  <table class="specs">
    <tbody>
      {product.specs.map((s) => (
        <tr><td>{s.label}</td><td><strong>{s.value}</strong></td></tr>
      ))}
    </tbody>
  </table>

  <h2>Применение</h2>
  <p>{product.application}</p>

  <h2>Расход и объём</h2>
  <p>{product.consumption}</p>

  {product.relatedCalc && (
    <div class="calc-cta">
      💡 Для точного расчёта объёма используйте <a href={product.relatedCalc.href}>{product.relatedCalc.label}</a>
    </div>
  )}

  <Rsya slot="middle" />

  <div class="two-col">
    <div class="pros">
      <h2>Плюсы</h2>
      <ul>{product.pros.map((p) => <li>{p}</li>)}</ul>
    </div>
    <div class="cons">
      <h2>Минусы</h2>
      <ul>{product.cons.map((c) => <li>{c}</li>)}</ul>
    </div>
  </div>

  <AffiliateLinks material={affMaterial} />
  <Faq items={product.faqs} />
  <Rsya slot="bottom" />

  {related.length > 0 && (
    <section class="related">
      <h2>Похожие материалы</h2>
      <ul class="related-list">
        {related.map((p) => <li><a href={`/brand/${p.slug}/`}>{p.brand} {p.product}</a></li>)}
      </ul>
    </section>
  )}
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .lead { font-size: 17px; color: #444; }
  .specs { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
  .specs td { padding: 10px 14px; border-bottom: 1px solid #e6e8eb; }
  .specs td:first-child { color: #666; }
  .specs strong { color: #1a1a1a; }
  .calc-cta {
    background: #eef3fb;
    border-left: 3px solid #0a5cce;
    padding: 12px 16px;
    border-radius: 4px;
    margin: 16px 0 24px;
    font-size: 15px;
  }
  .calc-cta a { font-weight: 600; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 24px 0; }
  .pros, .cons { background: #f7f8fa; padding: 16px 18px; border-radius: 8px; }
  .pros { border-left: 3px solid #16933b; }
  .cons { border-left: 3px solid #d09b1a; }
  .pros h2, .cons h2 { font-size: 17px; margin: 0 0 10px; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 12px 0 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) {
    .two-col, .related-list { grid-template-columns: 1fr; }
  }
</style>
