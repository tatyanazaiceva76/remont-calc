---
import Base from '~/layouts/Base.astro';
import { materialBrands } from '~/data/material-brands';

export function getStaticPaths() {
  return materialBrands.map((b) => ({ params: { brand: b.slug }, props: { brand: b } }));
}

const { brand } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const title = `${brand.name} — обзор 2026: цены, плюсы, минусы, линейки`;
const description = brand.shortDescription;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://www.kalkremont.ru/' },
    { '@type': 'ListItem', position: 2, name: 'Бренды', item: 'https://www.kalkremont.ru/brendy/' },
    { '@type': 'ListItem', position: 3, name: brand.name, item: url }
  ]
};
---
<Base title={title} description={description} canonical={url}>
  <nav class="breadcrumb">
    <a href="/">Главная</a> ›
    <a href="/brendy/">Бренды</a> ›
    <span>{brand.name}</span>
  </nav>

  <h1>🏷️ {brand.name} — обзор 2026</h1>
  <div class="lead">
    <p><strong>{brand.shortDescription}</strong></p>
    <p><span class="tag">🌍 {brand.origin}</span> <span class="tag">📦 {brand.category}</span> <span class="tag">💰 {brand.priceRange}</span></p>
  </div>

  <section>
    <h2>📖 О бренде</h2>
    <p>{brand.description}</p>
  </section>

  <section>
    <h2>🏆 Популярные линейки</h2>
    <div class="lines">
      {brand.popularLines.map((l) => (
        <div class="line">
          <strong>{l.name}</strong>
          <p>{l.description}</p>
          <span class="price">{l.price}</span>
        </div>
      ))}
    </div>
  </section>

  <div class="two-col">
    <section>
      <h2 style="color:#27ae60;">✅ Плюсы</h2>
      <ul>{brand.pros.map((p) => <li>{p}</li>)}</ul>
    </section>
    <section>
      <h2 style="color:#e67e22;">⚠️ Минусы</h2>
      <ul>{brand.cons.map((c) => <li>{c}</li>)}</ul>
    </section>
  </div>

  <section>
    <h2>❓ FAQ — {brand.name}</h2>
    <div class="faqs">
      {brand.faqs.map((f) => (
        <div class="faq">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="cta">
    <h2>💡 Калькулятор расхода {brand.category}</h2>
    <p>Рассчитайте сколько {brand.category} нужно для вашей квартиры:</p>
    <a href="/kalkulyator/" class="btn">→ Калькуляторы материалов</a>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: brand.faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a }
    }))
  })} />
</Base>
<style>
  .breadcrumb { font-size: 13px; color: #888; margin-bottom: 16px; }
  .breadcrumb a { color: #888; text-decoration: none; }
  .lead { padding: 18px 22px; background: #fffaf3; border-left: 4px solid #f5a623; border-radius: 0 8px 8px 0; }
  .lead p { margin: 8px 0; font-size: 16px; }
  .tag { display: inline-block; padding: 4px 10px; background: white; border-radius: 12px; font-size: 12px; color: #555; margin-right: 6px; }
  section h2 { font-size: 20px; color: #c0392b; margin-top: 28px; }
  .lines { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }
  .line { padding: 14px 16px; background: #fff; border: 1px solid #e6e8eb; border-radius: 10px; }
  .line strong { display: block; color: #c0392b; font-size: 15px; }
  .line p { font-size: 13px; color: #555; margin: 6px 0; }
  .line .price { display: inline-block; font-size: 13px; font-weight: 600; color: #2980b9; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .two-col ul { padding-left: 18px; }
  .two-col li { padding: 4px 0; font-size: 14px; }
  .faqs { display: flex; flex-direction: column; gap: 12px; }
  .faq { background: #fff; padding: 12px 16px; border: 1px solid #e6e8eb; border-radius: 8px; }
  .faq h3 { font-size: 15px; margin: 0 0 6px; }
  .faq p { margin: 0; font-size: 14px; color: #555; }
  .cta { background: #fff7e6; padding: 20px 24px; border-radius: 12px; margin-top: 32px; }
  .btn { display: inline-block; padding: 12px 24px; background: #c0392b; color: white; text-decoration: none; border-radius: 6px; font-weight: 600; margin-top: 8px; }
  @media (max-width: 700px) { .lines, .two-col { grid-template-columns: 1fr; } }
</style>
