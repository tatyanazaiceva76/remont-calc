---
import Base from '~/layouts/Base.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { articles } from '~/data/sovety-articles';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}
const { article } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Советы', item: `https://${SITE_CONFIG.domain}/sovety/` },
    { '@type': 'ListItem', position: 3, name: article.h1, item: url }
  ]
};
const articleSchema = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: article.h1,
  description: article.description,
  inLanguage: 'ru-RU',
  url
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs, articleSchema] };
const related = articles.filter((a) => a.slug !== article.slug).slice(0, 6);
---
<Base title={article.title} description={article.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/sovety/">Советы</a><span>›</span>
    <span>{article.h1}</span>
  </nav>

  <article>
    <h1>{article.h1}</h1>
    <p class="lead">{article.intro}</p>

    {article.relatedCalc && (
      <div class="calc-cta">
        💡 Для точного расчёта материалов используйте наш <a href={article.relatedCalc.href}>{article.relatedCalc.label}</a>
      </div>
    )}

    <Rsya slot="top" />

    {article.sections.map((s, i) => (
      <section>
        <h2>{s.h2}</h2>
        {s.paragraphs.map((p) => <p>{p}</p>)}
        {s.list && <ul>{s.list.map((li) => <li>{li}</li>)}</ul>}
        {i === Math.floor(article.sections.length / 2) && (
          <div class="mid-rsya"><Rsya slot="middle" /></div>
        )}
      </section>
    ))}

    {article.relatedCalc && (
      <div class="calc-cta calc-cta-bottom">
        <h3>Готовы посчитать?</h3>
        <p>Перейдите в калькулятор и узнайте точное количество материала для вашей комнаты — за секунду, без регистрации.</p>
        <a href={article.relatedCalc.href} class="calc-btn">{article.relatedCalc.label} →</a>
      </div>
    )}

    <Faq items={article.faqs} />
    <Rsya slot="bottom" />
  </article>

  <section class="related">
    <h2>Похожие советы</h2>
    <ul class="related-list">
      {related.map((a) => <li><a href={`/sovety/${a.slug}/`}>{a.h1}</a></li>)}
    </ul>
  </section>
</Base>

<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .lead { font-size: 17px; color: #444; }
  article h2 { font-size: 22px; margin-top: 32px; }
  article p { margin-bottom: 12px; line-height: 1.65; }
  .calc-cta {
    background: #eef3fb;
    border-left: 3px solid #0a5cce;
    padding: 12px 16px;
    border-radius: 4px;
    margin: 16px 0 24px;
    font-size: 15px;
  }
  .calc-cta a { font-weight: 600; }
  .calc-cta-bottom {
    margin: 32px 0;
    background: linear-gradient(135deg, #0a5cce 0%, #1565c0 100%);
    color: #fff;
    border-left: none;
    padding: 24px;
    border-radius: 10px;
  }
  .calc-cta-bottom h3 { color: #fff; margin: 0 0 8px; }
  .calc-cta-bottom p { color: #d4e3f8; margin: 0 0 16px; }
  .calc-btn {
    display: inline-block;
    padding: 12px 24px;
    background: #ffc107;
    color: #2d1f00 !important;
    border-radius: 6px;
    font-weight: 600;
  }
  .calc-btn:hover { background: #ffd54f; text-decoration: none; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 12px 0 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) { .related-list { grid-template-columns: 1fr; } }
</style>
