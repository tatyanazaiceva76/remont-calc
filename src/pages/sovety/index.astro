---
import Base from '~/layouts/Base.astro';
import Rsya from '~/components/Rsya.astro';
import { articlesByCategory } from '~/data/sovety-articles';
import { SITE_CONFIG } from '~/config';

const title = 'Советы по ремонту — гайды и инструкции';
const description = 'Подробные инструкции "как сделать самому" для ремонта квартиры: обои, ламинат, плитка, краска, штукатурка и другие работы.';
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Советы', item: url }
  ]
};
const cats: Record<string, string> = {
  'how-to': 'Как сделать самому',
  choice: 'Как выбрать',
  process: 'Процесс ремонта'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs"><a href="/">Главная</a><span>›</span><span>Советы</span></nav>
  <h1>Советы по ремонту</h1>
  <p>Подробные пошаговые инструкции для самостоятельного ремонта. После каждой статьи — ссылка на калькулятор материалов.</p>

  <Rsya slot="top" />

  {Object.entries(articlesByCategory).map(([cat, list]) => (
    <section>
      <h2>{cats[cat]}</h2>
      <ul class="articles">
        {list.map((a) => (
          <li>
            <a href={`/sovety/${a.slug}/`}>
              <h3>{a.h1}</h3>
              <p>{a.intro.slice(0, 160)}...</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <Rsya slot="bottom" />
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .articles { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 16px 0 32px; }
  .articles a {
    display: block;
    padding: 16px 18px;
    background: #f7f8fa;
    border: 1px solid #e6e8eb;
    border-radius: 8px;
    color: #1a1a1a;
    text-decoration: none;
  }
  .articles a:hover { background: #eef3fb; border-color: #0a5cce; }
  .articles h3 { font-size: 16px; margin: 0 0 6px; color: #0a5cce; }
  .articles p { font-size: 13px; color: #555; margin: 0; line-height: 1.5; }
  @media (max-width: 540px) { .articles { grid-template-columns: 1fr; } }
</style>
