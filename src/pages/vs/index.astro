---
import Base from '~/layouts/Base.astro';
import { comparisons } from '~/data/comparisons-vs';

const title = `Сравнения материалов и решений для ремонта — ${comparisons.length} пар`;
const description = `Подробные сравнения "${comparisons[0].a} vs ${comparisons[0].b}" и ${comparisons.length - 1} других. Объективный анализ с ценами 2026.`;
---
<Base title={title} description={description}>
  <h1>⚖️ Сравнения для ремонта — что лучше выбрать</h1>
  <p class="lead">Все типовые вопросы выбора материалов и подходов в одном месте. Объективные сравнения с ценами 2026 года.</p>

  <div class="grid">
    {comparisons.map((c) => (
      <a href={`/vs/${c.slug}/`} class="card">
        <div class="vs-line">
          <span class="a">{c.a}</span>
          <span class="vs">vs</span>
          <span class="b">{c.b}</span>
        </div>
        <p>{c.intro.slice(0, 130)}…</p>
      </a>
    ))}
  </div>
</Base>
<style>
  .lead { font-size: 16px; color: #555; margin-bottom: 32px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .card { display: block; padding: 18px 22px; background: #fff; border: 1px solid #e6e8eb; border-radius: 10px; text-decoration: none; color: #1a1a1a; transition: all 0.2s; }
  .card:hover { border-color: #f5a623; background: #fffbf3; transform: translateY(-3px); box-shadow: 0 6px 16px rgba(0,0,0,0.08); }
  .vs-line { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .a, .b { font-weight: 700; font-size: 15px; flex: 1; color: #c0392b; }
  .a { text-align: left; }
  .b { text-align: right; color: #2980b9; }
  .vs { padding: 4px 10px; background: #f5a623; color: white; font-size: 11px; font-weight: 800; border-radius: 12px; margin: 0 10px; }
  .card p { font-size: 13px; color: #555; margin: 0; line-height: 1.5; }
  @media (max-width: 700px) { .grid { grid-template-columns: 1fr; } }
</style>
