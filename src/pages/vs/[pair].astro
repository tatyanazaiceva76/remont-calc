---
import Base from '~/layouts/Base.astro';
import { comparisons } from '~/data/comparisons-vs';

export function getStaticPaths() {
  return comparisons.map((c) => ({ params: { pair: c.slug }, props: { c } }));
}

const { c } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: c.title,
  description: c.description,
  about: [c.a, c.b]
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://www.kalkremont.ru/' },
    { '@type': 'ListItem', position: 2, name: 'Сравнения', item: 'https://www.kalkremont.ru/vs/' },
    { '@type': 'ListItem', position: 3, name: `${c.a} vs ${c.b}`, item: url }
  ]
};
---
<Base title={c.title} description={c.description} canonical={url} schema={schema}>
  <nav class="breadcrumb">
    <a href="/">Главная</a> ›
    <a href="/vs/">Сравнения</a> ›
    <span>{c.a} vs {c.b}</span>
  </nav>

  <h1>⚖️ {c.a} или {c.b}: что выбрать в 2026</h1>
  <p class="lead">{c.intro}</p>

  <section class="table-wrap">
    <h2>📊 Сравнение по критериям</h2>
    <table class="compare">
      <thead>
        <tr><th>Критерий</th><th class="a">{c.a}</th><th class="b">{c.b}</th></tr>
      </thead>
      <tbody>
        {c.criteria.map((cr) => (
          <tr>
            <td>{cr.name}</td>
            <td>{cr.a}</td>
            <td>{cr.b}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="conclusion">
    <h2>🎯 Вывод</h2>
    <p>{c.conclusion}</p>
  </section>

  <div class="two-col">
    <section class="when">
      <h2 class="a">✅ Когда выбрать {c.a}</h2>
      <ul>{c.whenA.map((w) => <li>{w}</li>)}</ul>
    </section>
    <section class="when">
      <h2 class="b">✅ Когда выбрать {c.b}</h2>
      <ul>{c.whenB.map((w) => <li>{w}</li>)}</ul>
    </section>
  </div>

  <section>
    <h2>❓ FAQ</h2>
    <div class="faqs">
      {c.faqs.map((f) => (
        <div class="faq">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="cta">
    <h2>💡 Рассчитать стоимость</h2>
    <p>Получите точный расчёт ремонта для вашей квартиры:</p>
    <a href="/" class="btn">→ Калькулятор ремонта</a>
  </section>

  <section style="margin-top:32px;">
    <a href="/vs/" style="color:#888;">← Другие сравнения</a>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a }
    }))
  })} />
</Base>
<style>
  .breadcrumb { font-size: 13px; color: #888; margin-bottom: 16px; }
  .breadcrumb a { color: #888; text-decoration: none; }
  .lead { font-size: 17px; color: #444; line-height: 1.6; padding: 16px 20px; background: #fffaf3; border-left: 4px solid #f5a623; border-radius: 0 8px 8px 0; }
  .table-wrap { margin: 32px 0; overflow-x: auto; }
  .compare { width: 100%; border-collapse: collapse; }
  .compare th, .compare td { padding: 10px 14px; text-align: left; border-bottom: 1px solid #eee; }
  .compare thead th { background: #fff7e6; font-weight: 700; }
  .compare thead .a { color: #c0392b; }
  .compare thead .b { color: #2980b9; }
  .compare tr:hover { background: #fafafa; }
  .conclusion { padding: 20px 24px; background: #e8f4f8; border-radius: 10px; }
  .conclusion p { margin: 0; font-size: 16px; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 32px 0; }
  .when { padding: 18px 20px; background: #fff; border: 1px solid #e6e8eb; border-radius: 10px; }
  .when h2 { font-size: 16px; margin: 0 0 12px; }
  .when h2.a { color: #c0392b; }
  .when h2.b { color: #2980b9; }
  .when ul { margin: 0; padding-left: 18px; font-size: 14px; }
  .when li { padding: 4px 0; }
  .faqs { display: flex; flex-direction: column; gap: 12px; }
  .faq { background: #fff; padding: 12px 16px; border: 1px solid #e6e8eb; border-radius: 8px; }
  .faq h3 { font-size: 15px; margin: 0 0 6px; }
  .faq p { margin: 0; font-size: 14px; color: #555; }
  .cta { background: #fff7e6; padding: 20px 24px; border-radius: 10px; margin-top: 32px; }
  .btn { display: inline-block; padding: 12px 24px; background: #c0392b; color: white; text-decoration: none; border-radius: 6px; font-weight: 600; margin-top: 8px; }
  @media (max-width: 700px) { .two-col { grid-template-columns: 1fr; } }
</style>
