---
import Base from '~/layouts/Base.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import { comparisons } from '~/data/comparison-pages';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return comparisons.map((c) => ({ params: { slug: c.slug }, props: { cmp: c } }));
}
const { cmp } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Что лучше', item: `https://${SITE_CONFIG.domain}/chto-luchshe/` },
    { '@type': 'ListItem', position: 3, name: cmp.h1, item: url }
  ]
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs] };
const related = comparisons.filter((c) => c.slug !== cmp.slug).slice(0, 6);
---
<Base title={cmp.title} description={cmp.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a><span>›</span>
    <a href="/chto-luchshe/">Что лучше</a><span>›</span>
    <span>{cmp.h1}</span>
  </nav>

  <h1>{cmp.h1}</h1>
  <p class="lead">{cmp.intro}</p>

  <Rsya slot="top" />

  <h2>Сравнительная таблица</h2>
  <table class="cmp-table">
    <thead>
      <tr><th>Параметр</th><th>{cmp.optionA}</th><th>{cmp.optionB}</th></tr>
    </thead>
    <tbody>
      {cmp.rows.map((r) => (
        <tr><td>{r.param}</td><td>{r.a}</td><td>{r.b}</td></tr>
      ))}
    </tbody>
  </table>

  <div class="two-col">
    <div class="when-block">
      <h2>Когда лучше {cmp.optionA}</h2>
      <ul>{cmp.whenA.map((w) => <li>{w}</li>)}</ul>
    </div>
    <div class="when-block">
      <h2>Когда лучше {cmp.optionB}</h2>
      <ul>{cmp.whenB.map((w) => <li>{w}</li>)}</ul>
    </div>
  </div>

  <Rsya slot="middle" />

  <div class="verdict">
    <h2>Вывод</h2>
    <p>{cmp.verdict}</p>
  </div>

  {cmp.relatedCalc && (
    <div class="calc-cta-bottom">
      <h3>Готовы посчитать материал?</h3>
      <p>Точный расчёт количества и стоимости — в нашем калькуляторе.</p>
      <a href={cmp.relatedCalc.href} class="calc-btn">{cmp.relatedCalc.label} →</a>
    </div>
  )}

  <Faq items={cmp.faqs} />
  <Rsya slot="bottom" />

  <section class="related">
    <h2>Другие сравнения</h2>
    <ul class="related-list">
      {related.map((c) => <li><a href={`/chto-luchshe/${c.slug}/`}>{c.h1}</a></li>)}
    </ul>
  </section>
</Base>
<style>
  .breadcrumbs { font-size: 13px; color: #777; margin: 0 0 16px; display: flex; gap: 6px; flex-wrap: wrap; }
  .breadcrumbs a { color: #555; }
  .lead { font-size: 17px; color: #444; }
  .cmp-table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
  .cmp-table th, .cmp-table td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #e6e8eb; }
  .cmp-table thead th { background: #f7f8fa; font-weight: 600; }
  .cmp-table thead th:nth-child(2), .cmp-table td:nth-child(2) { color: #0a5cce; font-weight: 500; }
  .cmp-table thead th:nth-child(3), .cmp-table td:nth-child(3) { color: #16933b; font-weight: 500; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 32px 0; }
  .when-block { background: #f7f8fa; border-left: 3px solid #0a5cce; padding: 16px 18px; border-radius: 4px; }
  .when-block:nth-child(2) { border-left-color: #16933b; }
  .when-block h2 { font-size: 18px; margin: 0 0 10px; }
  .verdict { background: #fff8e1; border: 1px solid #f3d99a; border-radius: 8px; padding: 20px; margin: 32px 0; }
  .verdict h2 { margin-top: 0; }
  .calc-cta-bottom { background: linear-gradient(135deg, #0a5cce, #1565c0); color: #fff; padding: 24px; border-radius: 10px; margin: 32px 0; }
  .calc-cta-bottom h3, .calc-cta-bottom p { color: #fff; }
  .calc-cta-bottom p { color: #d4e3f8; margin: 0 0 16px; }
  .calc-btn { display: inline-block; padding: 12px 24px; background: #ffc107; color: #2d1f00 !important; border-radius: 6px; font-weight: 600; }
  .calc-btn:hover { background: #ffd54f; text-decoration: none; }
  .related { margin: 40px 0 0; }
  .related-list { list-style: none; padding: 0; margin: 12px 0 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px 16px; }
  .related-list a { display: block; padding: 8px 12px; background: #f7f8fa; border-radius: 6px; border: 1px solid #e6e8eb; font-size: 14px; }
  .related-list a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) {
    .two-col, .related-list { grid-template-columns: 1fr; }
    .cmp-table { font-size: 12px; }
  }
</style>
