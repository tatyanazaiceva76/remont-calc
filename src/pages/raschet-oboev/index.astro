---
import Base from '~/layouts/Base.astro';
import WallpaperCalc from '~/components/WallpaperCalc.astro';
import Rsya from '~/components/Rsya.astro';
import { scenariosByCategory } from '~/data/wallpaper-scenarios';
import { SITE_CONFIG } from '~/config';

const title = 'Калькулятор обоев онлайн — расчёт количества рулонов';
const description = 'Точный онлайн-калькулятор расчёта обоев на комнату. Учитываем рапорт, ширину рулона, окна и двери. Бесплатно, без регистрации.';
const url = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт обоев', item: url }
  ]
};

const categoryTitles = {
  area: 'По площади комнаты',
  'room-type': 'По типу комнаты',
  'roll-type': 'По типу рулона',
  feature: 'По особенностям обоев',
  combo: 'Комбинированные расчёты'
};
---
<Base title={title} description={description} canonical={url} schema={breadcrumbs}>
  <nav class="breadcrumbs">
    <a href="/">Главная</a>
    <span>›</span>
    <span>Расчёт обоев</span>
  </nav>

  <h1>Калькулятор обоев онлайн</h1>
  <p>
    Введите размеры комнаты и параметры рулона — калькулятор покажет точное количество рулонов обоев с запасом 10%.
    Учитываются окна, двери и рапорт (повтор рисунка).
  </p>

  <WallpaperCalc />

  <Rsya slot="top" />

  <h2>Как пользоваться калькулятором</h2>
  <ol>
    <li>Замерьте длину, ширину и высоту комнаты.</li>
    <li>Укажите количество дверей и окон (используются типовые размеры: дверь 0,9 × 2,0 м, окно 1,5 × 1,4 м).</li>
    <li>Выберите ширину рулона: 0,53 м (узкие), 0,7 м или 1,06 м (метровые).</li>
    <li>Укажите длину рулона и рапорт (для обоев с рисунком).</li>
    <li>Готово — справа появится количество рулонов и общая площадь стен.</li>
  </ol>

  <h2>Готовые расчёты для типовых случаев</h2>
  <p>Если не хочется вводить параметры вручную — выберите готовый сценарий с предзаполненными значениями.</p>

  {Object.entries(scenariosByCategory).map(([cat, list]) => (
    <section>
      <h3>{categoryTitles[cat as keyof typeof categoryTitles]}</h3>
      <ul class="links">
        {list.map((s) => (
          <li><a href={`/raschet-oboev/${s.slug}/`}>{s.h1}</a></li>
        ))}
      </ul>
    </section>
  ))}

  <Rsya slot="bottom" />
</Base>

<style>
  .breadcrumbs {
    font-size: 13px;
    color: #777;
    margin: 0 0 16px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumbs a { color: #555; }
  ol { padding-left: 20px; }
  ol li { margin-bottom: 6px; }
  .links {
    list-style: none;
    padding: 0;
    margin: 12px 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 14px;
  }
  .links a {
    display: block;
    padding: 6px 10px;
    background: #f7f8fa;
    border: 1px solid #e6e8eb;
    border-radius: 6px;
    font-size: 14px;
  }
  .links a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) {
    .links { grid-template-columns: 1fr; }
  }
</style>
