---
import Base from '~/layouts/Base.astro';
import WallpaperCalc from '~/components/WallpaperCalc.astro';
import Rsya from '~/components/Rsya.astro';
import Faq from '~/components/Faq.astro';
import RelatedScenarios from '~/components/RelatedScenarios.astro';
import CrossCalcLinks from '~/components/CrossCalcLinks.astro';
import { scenarios } from '~/data/wallpaper-scenarios';
import { laminateScenarios } from '~/data/laminate-scenarios';
import { paintScenarios } from '~/data/paint-scenarios';
import { tileScenarios } from '~/data/tile-scenarios';
import { getCrossLinks } from '~/data/cross-links';
import { wallpaperFAQs } from '~/data/faqs';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  return scenarios.map((s) => ({
    params: { slug: s.slug },
    props: { scenario: s }
  }));
}

const { scenario } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Расчёт обоев', item: `https://${SITE_CONFIG.domain}/raschet-oboev/` },
    { '@type': 'ListItem', position: 3, name: scenario.h1, item: url }
  ]
};

const howTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: scenario.h1,
  description: scenario.description,
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Измерьте комнату', text: 'Замерьте длину, ширину и высоту комнаты в метрах.' },
    { '@type': 'HowToStep', position: 2, name: 'Укажите параметры рулона', text: 'Введите ширину и длину рулона обоев — обычно указаны на этикетке.' },
    { '@type': 'HowToStep', position: 3, name: 'Учтите рапорт', text: 'Если у обоев есть рисунок — укажите рапорт в сантиметрах.' },
    { '@type': 'HowToStep', position: 4, name: 'Получите результат', text: 'Калькулятор покажет необходимое количество рулонов с учётом запаса 10%.' }
  ]
};

const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs, howTo] };

const crossLinks = getCrossLinks('wallpaper', scenario.slug, {
  wallpaper: scenarios,
  laminate: laminateScenarios,
  paint: paintScenarios,
  tile: tileScenarios
});
---
<Base title={scenario.title} description={scenario.description} canonical={url} schema={schema}>
  <nav class="breadcrumbs" aria-label="Навигация">
    <a href="/">Главная</a>
    <span>›</span>
    <a href="/raschet-oboev/">Расчёт обоев</a>
    <span>›</span>
    <span>{scenario.h1}</span>
  </nav>

  <h1>{scenario.h1}</h1>

  {scenario.introBlocks[0] && <p>{scenario.introBlocks[0]}</p>}

  <WallpaperCalc prefill={scenario.prefill} lock={scenario.lock} />

  <Rsya slot="top" />

  {scenario.introBlocks.slice(1).map((block) => <p>{block}</p>)}

  <h2>Как работает калькулятор</h2>
  <p>
    Калькулятор берёт периметр комнаты, вычитает площадь дверных и оконных проёмов и считает, сколько полос нужной высоты помещается в одном рулоне.
    Каждое значение легко изменить — пересчёт происходит мгновенно.
  </p>
  <p>
    Если у обоев есть рапорт (повтор рисунка), длина каждой полосы округляется до следующего полного шага рапорта. Это автоматически учитывает отходы при подгонке узора.
  </p>

  <Rsya slot="middle" />

  <h2>Что важно учесть</h2>
  <ul>
    <li><strong>Высота потолка.</strong> При высоте 2,7 м из стандартного рулона 10,05 м получается 3 полосы. При 3,0 м — уже только 3 полосы с большими отходами.</li>
    <li><strong>Партия.</strong> Все рулоны должны быть из одной партии. На этикетке указан номер — он должен совпадать.</li>
    <li><strong>Запас.</strong> Калькулятор по умолчанию добавляет 10%. Для обоев с крупным рисунком берите 15%, для очень сложного раппорта — 20%.</li>
    <li><strong>Проёмы.</strong> Учитываются стандартные размеры: дверь 0,9 × 2,0 м, окно 1,5 × 1,4 м. Если у вас нестандартные — поправьте количество.</li>
  </ul>

  <Faq items={wallpaperFAQs} />
  <CrossCalcLinks links={crossLinks} />
  <Rsya slot="bottom" />

  <RelatedScenarios current={scenario.slug} scenarios={scenarios} limit={10} />
</Base>

<style>
  .breadcrumbs {
    font-size: 13px;
    color: #777;
    margin: 0 0 16px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumbs a { color: #555; }
  ul { padding-left: 20px; }
  ul li { margin-bottom: 8px; }
</style>
