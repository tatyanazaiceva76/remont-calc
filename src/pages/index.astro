---
import Base from '~/layouts/Base.astro';
import { SITE_CONFIG } from '~/config';
import { scenarios } from '~/data/wallpaper-scenarios';
import { laminateScenarios } from '~/data/laminate-scenarios';
import { paintScenarios } from '~/data/paint-scenarios';
import { tileScenarios } from '~/data/tile-scenarios';

const title = `${SITE_CONFIG.siteName} — онлайн-калькуляторы материалов`;
const description = SITE_CONFIG.siteDescription;
const url = new URL('/', Astro.site).href;

const popular = [
  { href: '/raschet-oboev/na-komnatu-18-kv-m/', title: 'Обои на комнату 18 м²' },
  { href: '/raschet-oboev/na-spalnyu/', title: 'Обои на спальню' },
  { href: '/raschet-laminata/na-komnatu-20-kv-m/', title: 'Ламинат на комнату 20 м²' },
  { href: '/raschet-laminata/diagonalnaya-ukladka/', title: 'Ламинат диагонально' },
  { href: '/raschet-kraski/na-komnatu-15-kv-m/', title: 'Краска на комнату 15 м²' },
  { href: '/raschet-kraski/na-potolok/', title: 'Краска на потолок' },
  { href: '/raschet-plitki/na-vannuyu/', title: 'Плитка на ванную' },
  { href: '/raschet-plitki/30x30/', title: 'Плитка 30 × 30 см' }
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.siteName,
  url: `https://${SITE_CONFIG.domain}/`,
  inLanguage: 'ru-RU',
  description: SITE_CONFIG.siteDescription
};
---
<Base title={title} description={description} canonical={url} schema={websiteSchema}>
  <h1>Онлайн-калькуляторы для ремонта</h1>
  <p>
    Точные расчёты строительных материалов: обои, ламинат, краска.
    Без регистрации, мгновенный результат, реальные формулы.
  </p>

  <section>
    <h2>Калькуляторы</h2>
    <div class="cards">
      <a href="/raschet-oboev/" class="card">
        <h3>Расчёт обоев</h3>
        <p>{scenarios.length} готовых сценариев. Учитывает рапорт, ширину рулона, проёмы.</p>
        <span class="card-link">Открыть →</span>
      </a>
      <a href="/raschet-laminata/" class="card">
        <h3>Расчёт ламината</h3>
        <p>{laminateScenarios.length} сценариев. Прямая, диагональная укладка и ёлочка.</p>
        <span class="card-link">Открыть →</span>
      </a>
      <a href="/raschet-kraski/" class="card">
        <h3>Расчёт краски</h3>
        <p>{paintScenarios.length} сценариев. Литры, фасовка банок, стоимость.</p>
        <span class="card-link">Открыть →</span>
      </a>
      <a href="/raschet-plitki/" class="card">
        <h3>Расчёт плитки</h3>
        <p>{tileScenarios.length} сценариев. Все форматы, прямая и диагональная укладка.</p>
        <span class="card-link">Открыть →</span>
      </a>
    </div>
  </section>

  <section>
    <h2>Популярные расчёты</h2>
    <ul class="popular">
      {popular.map((p) => <li><a href={p.href}>{p.title}</a></li>)}
    </ul>
  </section>

  <section>
    <h2>Зачем использовать калькулятор</h2>
    <p>
      Опытные строители советуют: купить с запасом — это нормально, а вот докупать в процессе ремонта почти всегда означает оттенок из другой партии и заметные стыки. С другой стороны, лишние 5-10 рулонов обоев — это ощутимые деньги, которые потом долго будут лежать без дела.
    </p>
    <p>
      Все калькуляторы на сайте используют реальные формулы (а не упрощённое «площадь × 1,5»), учитывают рапорт, проёмы, тип укладки и стандарты фасовок. Результат — точное количество материала, которое реально нужно купить.
    </p>
  </section>
</Base>

<style>
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 0;
  }
  .card {
    display: block;
    padding: 18px 20px;
    background: #f7f8fa;
    border: 1px solid #e6e8eb;
    border-radius: 8px;
    color: #1a1a1a;
  }
  .card:hover { background: #eef3fb; text-decoration: none; border-color: #0a5cce; }
  .card h3 { margin: 0 0 8px; font-size: 17px; }
  .card p { font-size: 14px; color: #555; margin: 0 0 10px; }
  .card-link { color: #0a5cce; font-size: 14px; font-weight: 500; }
  .card-disabled { opacity: 0.55; cursor: default; }
  .card-disabled:hover { background: #f7f8fa; border-color: #e6e8eb; }
  .popular {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
  }
  .popular a {
    display: block;
    padding: 8px 12px;
    background: #f7f8fa;
    border-radius: 6px;
    border: 1px solid #e6e8eb;
    font-size: 14px;
  }
  .popular a:hover { background: #eef3fb; text-decoration: none; }
  @media (max-width: 540px) {
    .cards, .popular { grid-template-columns: 1fr; }
  }
</style>
