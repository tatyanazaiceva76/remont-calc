---
import Base from '~/layouts/Base.astro';
import { glossary, glossaryShort } from '~/data/glossary';

export function getStaticPaths() {
  const full = glossary.map((t) => ({
    params: { term: t.slug },
    props: { type: 'full', data: t }
  }));
  const short = glossaryShort.map((t) => ({
    params: { term: t.slug },
    props: { type: 'short', data: t }
  }));
  return [...full, ...short];
}

const { type, data } = Astro.props;
const isFull = type === 'full';

const title = `${data.term} — определение, цены, применение 2026 | Глоссарий ремонта`;
const description = `${data.short.slice(0, 145)}`;
const url = new URL(Astro.url.pathname, Astro.site).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: data.term,
  description: data.short,
  inDefinedTermSet: 'https://www.kalkremont.ru/slovar/',
  termCode: data.slug
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://www.kalkremont.ru/' },
    { '@type': 'ListItem', position: 2, name: 'Глоссарий', item: 'https://www.kalkremont.ru/slovar/' },
    { '@type': 'ListItem', position: 3, name: data.term, item: url }
  ]
};
---
<Base title={title} description={description} canonical={url} schema={schema}>
  <nav class="breadcrumb">
    <a href="/">Главная</a> ›
    <a href="/slovar/">Глоссарий</a> ›
    <span>{data.term}</span>
  </nav>

  <h1>{data.term}</h1>
  <p class="lead">{data.short}</p>

  {isFull && 'detail' in data && (
    <section class="detail">
      <h2>Подробнее</h2>
      {data.detail.split('\n\n').map((p) => <p>{p}</p>)}
    </section>
  )}

  {isFull && 'applications' in data && data.applications.length > 0 && (
    <section>
      <h2>📌 Где применяется</h2>
      <ul>
        {data.applications.map((a) => <li>{a}</li>)}
      </ul>
    </section>
  )}

  {isFull && 'faqs' in data && data.faqs.length > 0 && (
    <section>
      <h2>❓ Часто задаваемые вопросы</h2>
      <div class="faqs">
        {data.faqs.map((f) => (
          <div class="faq">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {isFull && 'related' in data && data.related.length > 0 && (
    <section>
      <h2>🔗 Связанные термины</h2>
      <ul class="related-list">
        {data.related.map((slug) => {
          const r = [...glossary, ...glossaryShort].find((t) => t.slug === slug);
          return r ? <li><a href={`/slovar/${slug}/`}>{r.term}</a> — {r.short.slice(0, 80)}…</li> : null;
        })}
      </ul>
    </section>
  )}

  {isFull && 'relatedCalc' in data && data.relatedCalc && (
    <section class="cta">
      <h2>💡 Рассчитать онлайн</h2>
      <p>Точный расчёт количества и стоимости — в нашем калькуляторе:</p>
      <a href={data.relatedCalc.href} class="btn">{data.relatedCalc.label} →</a>
    </section>
  )}

  <section class="back">
    <a href="/slovar/">← Все термины глоссария</a>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  {isFull && 'faqs' in data && data.faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a }
      }))
    })} />
  )}
</Base>
<style>
  .breadcrumb { font-size: 13px; color: #888; margin-bottom: 16px; }
  .breadcrumb a { color: #888; text-decoration: none; }
  .breadcrumb a:hover { color: #c0392b; }
  .lead { font-size: 18px; color: #333; padding: 16px 20px; background: #fffaf3; border-left: 4px solid #f5a623; margin: 16px 0 24px; border-radius: 0 8px 8px 0; }
  section { margin: 32px 0; }
  section h2 { font-size: 20px; color: #c0392b; }
  .detail p { margin-bottom: 12px; line-height: 1.6; white-space: pre-line; }
  .faqs { display: flex; flex-direction: column; gap: 16px; }
  .faq { background: #fff; padding: 14px 16px; border: 1px solid #e6e8eb; border-radius: 8px; }
  .faq h3 { font-size: 15px; margin: 0 0 8px; color: #1a1a1a; }
  .faq p { margin: 0; font-size: 14px; color: #555; line-height: 1.5; }
  .related-list { list-style: none; padding: 0; }
  .related-list li { padding: 6px 0; }
  .related-list a { color: #c0392b; }
  .cta { background: #fff7e6; padding: 20px; border-radius: 10px; }
  .btn { display: inline-block; padding: 12px 24px; background: #c0392b; color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; margin-top: 8px; }
  .back { margin-top: 48px; }
  .back a { color: #888; }
</style>
