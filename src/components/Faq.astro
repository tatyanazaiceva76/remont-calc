---
import type { FAQ } from '~/data/faqs';
interface Props { items: FAQ[]; }
const { items } = Astro.props;
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a }
  }))
};
---
<section class="faq">
  <h2>Частые вопросы</h2>
  {items.map((it) => (
    <details class="faq-item">
      <summary>{it.q}</summary>
      <p>{it.a}</p>
    </details>
  ))}
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq { margin: 32px 0 0; }
  .faq-item {
    border: 1px solid #e6e8eb;
    border-radius: 6px;
    background: #fff;
    margin-bottom: 8px;
    padding: 0;
  }
  .faq-item summary {
    cursor: pointer;
    padding: 12px 16px;
    font-weight: 600;
    font-size: 15px;
    list-style: none;
    position: relative;
    padding-right: 36px;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 22px;
    color: #0a5cce;
    line-height: 1;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p {
    padding: 0 16px 14px;
    margin: 0;
    color: #444;
    font-size: 14px;
    line-height: 1.55;
  }
</style>
