---
interface Props {
  prefill?: {
    length?: number;
    width?: number;
    rollWidth?: number;
    pricePerSqm?: number;
  };
  lock?: Array<'rollWidth'>;
}
const { prefill = {}, lock = [] } = Astro.props;
const defaults = {
  length: prefill.length ?? 5,
  width: prefill.width ?? 4,
  rollWidth: prefill.rollWidth ?? 3,
  pricePerSqm: prefill.pricePerSqm ?? 0
};
---
<div class="calc" id="lino-calc" data-defaults={JSON.stringify(defaults)}>
  <div class="calc-grid">
    <label><span>Длина комнаты, м</span><input type="number" name="length" min="0.5" max="50" step="0.1" value={defaults.length} /></label>
    <label><span>Ширина комнаты, м</span><input type="number" name="width" min="0.5" max="50" step="0.1" value={defaults.width} /></label>
    {!lock.includes('rollWidth') && (
      <label>
        <span>Ширина рулона, м</span>
        <select name="rollWidth">
          <option value="1.5" selected={defaults.rollWidth === 1.5}>1,5 м</option>
          <option value="2" selected={defaults.rollWidth === 2}>2 м</option>
          <option value="2.5" selected={defaults.rollWidth === 2.5}>2,5 м</option>
          <option value="3" selected={defaults.rollWidth === 3}>3 м</option>
          <option value="3.5" selected={defaults.rollWidth === 3.5}>3,5 м</option>
          <option value="4" selected={defaults.rollWidth === 4}>4 м</option>
          <option value="5" selected={defaults.rollWidth === 5}>5 м</option>
        </select>
      </label>
    )}
    <label class="full"><span>Цена за 1 м², ₽ <span class="hint">(необязательно)</span></span><input type="number" name="pricePerSqm" min="0" max="100000" step="50" value={defaults.pricePerSqm} placeholder="например, 450" /></label>
  </div>

  <div class="calc-result" aria-live="polite">
    <div class="rows">
      <div class="row"><span>Площадь пола</span><strong data-out="area">—</strong></div>
      <div class="row"><span>Тип раскроя</span><strong data-out="layout">—</strong></div>
      <div class="row"><span>Полос линолеума</span><strong data-out="strips">—</strong></div>
      <div class="row big"><span>Размер куска</span><strong data-out="piece">—</strong></div>
      <div class="row big"><span>Общая площадь с запасом</span><strong data-out="totalSqm">—</strong></div>
      <div class="row big cost" data-cost-row hidden><span>Стоимость материала</span><strong data-out="cost">—</strong></div>
    </div>
    <p class="hint-block" data-hint hidden></p>
  </div>
</div>

<script is:inline>
  (function () {
    const root = document.getElementById('lino-calc');
    if (!root) return;
    const inputs = root.querySelectorAll('input, select');
    const out = (k) => root.querySelector(`[data-out="${k}"]`);
    function num(n){const el=root.querySelector(`[name="${n}"]`);if(!el){const d=JSON.parse(root.getAttribute('data-defaults')||'{}');return Number(d[n])||0;}return parseFloat(el.value)||0;}
    function calc() {
      const L = num('length'), W = num('width');
      const rW = num('rollWidth');
      const area = L * W;

      // Стелим линолеум вдоль длинной стороны комнаты
      const longSide = Math.max(L, W);
      const shortSide = Math.min(L, W);

      // Лучший вариант: ширина рулона >= shortSide — одним куском
      let strips, pieceLength, totalSqm, layoutText;
      const hint = root.querySelector('[data-hint]');

      if (rW >= shortSide) {
        strips = 1;
        pieceLength = longSide + 0.1; // 10 см запас на подрезку
        totalSqm = pieceLength * rW;
        layoutText = 'Одним куском';
        if (hint) {
          hint.textContent = 'Идеально — без швов, минимум обрезков. Это оптимальный сценарий.';
          hint.removeAttribute('hidden');
        }
      } else {
        // Нужно несколько полос
        strips = Math.ceil(shortSide / rW);
        pieceLength = longSide + 0.1;
        totalSqm = strips * pieceLength * rW;
        layoutText = `${strips} полосы`;
        if (hint) {
          hint.textContent = `Рулона ширины ${rW} м не хватает на короткую сторону ${shortSide.toFixed(1)} м. Рассмотрите рулон от ${Math.ceil(shortSide * 2) / 2} м чтобы постелить без швов.`;
          hint.removeAttribute('hidden');
        }
      }

      const fmt = (n, s) => (Number.isFinite(n) ? n.toFixed(2).replace(/\.?0+$/, '') : '—') + (s || '');
      out('area').textContent = fmt(area, ' м²');
      out('layout').textContent = layoutText;
      out('strips').textContent = String(strips);
      out('piece').textContent = `${pieceLength.toFixed(2).replace(/\.?0+$/,'')} × ${rW} м`;
      out('totalSqm').textContent = fmt(totalSqm, ' м²');

      const price = num('pricePerSqm');
      const costRow = root.querySelector('[data-cost-row]');
      if (price > 0 && totalSqm > 0) {
        out('cost').textContent = Math.ceil(totalSqm * price).toLocaleString('ru-RU') + ' ₽';
        if (costRow) costRow.removeAttribute('hidden');
      } else if (costRow) costRow.setAttribute('hidden', '');
    }
    inputs.forEach((el) => el.addEventListener('input', calc));
    calc();
  })();
</script>

<style>
  .calc { background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 8px; padding: 20px; margin: 20px 0; }
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; }
  .calc-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 14px; color: #444; }
  .calc-grid label.full { grid-column: 1 / -1; }
  .calc-grid input, .calc-grid select { padding: 8px 10px; border: 1px solid #c8ccd0; border-radius: 6px; font-size: 15px; background: #fff; width: 100%; }
  .calc-grid input:focus, .calc-grid select:focus { outline: 2px solid #0a5cce; border-color: #0a5cce; }
  .calc-result { margin-top: 20px; background: #fff; border-radius: 6px; padding: 14px 16px; border: 1px solid #e6e8eb; }
  .rows { display: flex; flex-direction: column; gap: 8px; }
  .row { display: flex; justify-content: space-between; gap: 12px; font-size: 14px; color: #555; padding: 4px 0; }
  .row strong { color: #1a1a1a; font-weight: 600; }
  .row.big { font-size: 16px; border-top: 1px dashed #d8dade; padding-top: 10px; margin-top: 4px; }
  .row.big strong { color: #0a5cce; font-size: 18px; }
  .row.cost strong { color: #16933b; }
  .hint { color: #999; font-weight: 400; font-size: 12px; }
  .hint-block { background: #fff8e1; border-left: 3px solid #f5b939; padding: 10px 14px; margin: 12px 0 0; font-size: 13px; color: #5c4a09; border-radius: 4px; }
  @media (max-width: 540px) { .calc-grid { grid-template-columns: 1fr; } }
</style>
