---
// Лид-форма с отправкой в /api/lead (D1 + Telegram уведомление).
// БЕЗ WhatsApp — только нормальная форма + telegram-уведомление менеджеру.
interface Props {
  source?: string;
  title?: string;
  subtitle?: string;
  cta?: string;
}
const {
  source = 'unknown',
  title = '🎯 Получить расчёт',
  subtitle = 'Заполните форму — пришлём расчёт за 30 минут',
  cta = 'Получить расчёт →'
} = Astro.props;
---
<section class="lead-form" data-source={source}>
  <h2>{title}</h2>
  <p class="lf-sub">{subtitle}</p>
  <form id={`lf-${source}`} class="lf">
    <input type="tel" name="phone" placeholder="+7 (___) ___-__-__" required minlength="10" />
    <input type="text" name="name" placeholder="Как к вам обращаться" />
    <button type="submit">{cta}</button>
    <p class="lf-note">⏱ Перезвоним в течение 30 минут · 🔒 Без спама</p>
  </form>
  <div class="lf-success" style="display:none">
    <p><strong>✅ Заявка принята!</strong></p>
    <p>Менеджер перезвонит в течение 30 минут.</p>
  </div>
</section>

<style>
  .lead-form { background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); margin: 24px 0; max-width: 500px; }
  .lead-form h2 { margin: 0 0 6px; font-size: 22px; }
  .lf-sub { margin: 0 0 16px; color: #666; font-size: 14px; }
  .lf { display: flex; flex-direction: column; gap: 10px; }
  .lf input { padding: 14px 16px; border: 2px solid #e6e8eb; border-radius: 8px; font-size: 16px; }
  .lf input:focus { border-color: #c0392b; outline: none; }
  .lf button { padding: 14px; background: linear-gradient(135deg, #c0392b, #e74c3c); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 700; cursor: pointer; }
  .lf-note { font-size: 12px; color: #888; text-align: center; margin: 8px 0 0; }
  .lf-success { padding: 20px; background: #d4edda; border-radius: 8px; text-align: center; color: #155724; }
</style>

<script is:inline define:vars={{ source }}>
  document.getElementById('lf-' + source)?.addEventListener('submit', function(e) {
    e.preventDefault();
    const form = e.target;
    const wrapper = form.closest('.lead-form');
    const data = new FormData(form);
    fetch('/api/lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        phone: data.get('phone'),
        name: data.get('name'),
        source: source,
        page: location.pathname,
        url: location.href,
        host: location.hostname,
        referrer: document.referrer || null,
        ts: Date.now()
      })
    }).then(function(r) { return r.json(); }).then(function() {
      form.style.display = 'none';
      wrapper.querySelector('.lf-success').style.display = 'block';
      if (window.ym) window.ym((window.__YM_ID__||99000000), 'reachGoal', 'lead-submit');
    }).catch(function() {
      alert('Ошибка отправки. Попробуйте ещё раз.');
    });
  });
</script>
