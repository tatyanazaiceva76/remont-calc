---
interface Props {
  prefill?: {
    length?: number;
    width?: number;
    height?: number;
    thickness?: number; // мм
    surface?: 'walls' | 'roof' | 'floor' | 'all';
    packArea?: number;  // м² в упаковке
    pricePerPack?: number;
    doors?: number;
    windows?: number;
  };
  lock?: Array<'thickness' | 'surface' | 'packArea'>;
}
const { prefill = {}, lock = [] } = Astro.props;
const defaults = {
  length: prefill.length ?? 6,
  width: prefill.width ?? 5,
  height: prefill.height ?? 2.7,
  thickness: prefill.thickness ?? 100,
  surface: prefill.surface ?? 'walls',
  packArea: prefill.packArea ?? 6,
  doors: prefill.doors ?? 1,
  windows: prefill.windows ?? 2,
  pricePerPack: prefill.pricePerPack ?? 0
};
---
<div class="calc" id="ins-calc" data-defaults={JSON.stringify(defaults)}>
  <div class="calc-grid">
    <label><span>Длина, м</span><input type="number" name="length" min="0.5" max="100" step="0.1" value={defaults.length} /></label>
    <label><span>Ширина, м</span><input type="number" name="width" min="0.5" max="100" step="0.1" value={defaults.width} /></label>
    <label><span>Высота стен, м</span><input type="number" name="height" min="2.0" max="6.0" step="0.05" value={defaults.height} /></label>

    {!lock.includes('surface') && (
      <label>
        <span>Что утепляем</span>
        <select name="surface">
          <option value="walls" selected={defaults.surface === 'walls'}>Стены</option>
          <option value="roof" selected={defaults.surface === 'roof'}>Кровля / чердак</option>
          <option value="floor" selected={defaults.surface === 'floor'}>Пол</option>
          <option value="all" selected={defaults.surface === 'all'}>Полное утепление (стены + кровля + пол)</option>
        </select>
      </label>
    )}
    {!lock.includes('thickness') && (
      <label>
        <span>Толщина слоя, мм</span>
        <select name="thickness">
          <option value="50" selected={defaults.thickness === 50}>50 мм (внутри, балкон)</option>
          <option value="100" selected={defaults.thickness === 100}>100 мм (стандарт)</option>
          <option value="150" selected={defaults.thickness === 150}>150 мм (тёплая зона)</option>
          <option value="200" selected={defaults.thickness === 200}>200 мм (север РФ)</option>
        </select>
      </label>
    )}
    {!lock.includes('packArea') && (
      <label>
        <span>М² в упаковке</span>
        <input type="number" name="packArea" min="0.5" max="50" step="0.1" value={defaults.packArea} />
      </label>
    )}
    <label><span>Дверей</span><input type="number" name="doors" min="0" max="10" step="1" value={defaults.doors} /></label>
    <label><span>Окон</span><input type="number" name="windows" min="0" max="10" step="1" value={defaults.windows} /></label>
    <label class="full"><span>Цена за упаковку, ₽ <span class="hint">(необязательно)</span></span><input type="number" name="pricePerPack" min="0" max="100000" step="50" value={defaults.pricePerPack} placeholder="например, 1200" /></label>
  </div>

  <div class="calc-result" aria-live="polite">
    <div class="rows">
      <div class="row"><span>Площадь утепления</span><strong data-out="area">—</strong></div>
      <div class="row"><span>Объём утеплителя</span><strong data-out="volume">—</strong></div>
      <div class="row"><span>С запасом 5%</span><strong data-out="areaReserve">—</strong></div>
      <div class="row big"><span>Упаковок нужно</span><strong data-out="packs">—</strong></div>
      <div class="row big cost" data-cost-row hidden><span>Стоимость материала</span><strong data-out="cost">—</strong></div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const root = document.getElementById('ins-calc');
    if (!root) return;
    const inputs = root.querySelectorAll('input, select');
    const out = (k) => root.querySelector(`[data-out="${k}"]`);
    const DOOR_W = 0.9, DOOR_H = 2.0, WIN_W = 1.5, WIN_H = 1.4;
    function num(n){const el=root.querySelector(`[name="${n}"]`);if(!el){const d=JSON.parse(root.getAttribute('data-defaults')||'{}');return Number(d[n])||0;}return parseFloat(el.value)||0;}
    function str(n){const el=root.querySelector(`[name="${n}"]`);if(!el){const d=JSON.parse(root.getAttribute('data-defaults')||'{}');return String(d[n]||'');}return el.value;}
    function calc() {
      const L = num('length'), W = num('width'), H = num('height');
      const surface = str('surface');
      const thickness = num('thickness') / 1000; // в метры
      const packArea = num('packArea');
      const doors = num('doors'), windows = num('windows');

      const perimeter = 2 * (L + W);
      const wallArea = Math.max(0, perimeter * H - (doors * DOOR_W * DOOR_H + windows * WIN_W * WIN_H));
      const floorOrRoofArea = L * W;

      let area = 0;
      if (surface === 'walls') area = wallArea;
      else if (surface === 'roof') area = floorOrRoofArea * 1.15; // скаты увеличивают площадь
      else if (surface === 'floor') area = floorOrRoofArea;
      else area = wallArea + floorOrRoofArea * 1.15 + floorOrRoofArea;

      const volume = area * thickness;
      const areaReserve = area * 1.05;
      const packs = packArea > 0 ? Math.ceil(areaReserve / packArea) : 0;

      const fmt = (n, s) => (Number.isFinite(n) ? n.toFixed(2).replace(/\.?0+$/, '') : '—') + (s || '');
      out('area').textContent = fmt(area, ' м²');
      out('volume').textContent = fmt(volume, ' м³');
      out('areaReserve').textContent = fmt(areaReserve, ' м²');
      out('packs').textContent = String(packs) + ' уп';
      const price = num('pricePerPack');
      const costRow = root.querySelector('[data-cost-row]');
      if (price > 0 && packs > 0) {
        out('cost').textContent = (packs * price).toLocaleString('ru-RU') + ' ₽';
        if (costRow) costRow.removeAttribute('hidden');
      } else if (costRow) costRow.setAttribute('hidden', '');
    }
    inputs.forEach((el) => el.addEventListener('input', calc));
    calc();
  })();
</script>

<style>
  .calc { background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 8px; padding: 20px; margin: 20px 0; }
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; }
  .calc-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 14px; color: #444; }
  .calc-grid label.full { grid-column: 1 / -1; }
  .calc-grid input, .calc-grid select { padding: 8px 10px; border: 1px solid #c8ccd0; border-radius: 6px; font-size: 15px; background: #fff; width: 100%; }
  .calc-grid input:focus, .calc-grid select:focus { outline: 2px solid #0a5cce; border-color: #0a5cce; }
  .calc-result { margin-top: 20px; background: #fff; border-radius: 6px; padding: 14px 16px; border: 1px solid #e6e8eb; }
  .rows { display: flex; flex-direction: column; gap: 8px; }
  .row { display: flex; justify-content: space-between; gap: 12px; font-size: 14px; color: #555; padding: 4px 0; }
  .row strong { color: #1a1a1a; font-weight: 600; }
  .row.big { font-size: 16px; border-top: 1px dashed #d8dade; padding-top: 10px; margin-top: 4px; }
  .row.big strong { color: #0a5cce; font-size: 18px; }
  .row.cost strong { color: #16933b; }
  .hint { color: #999; font-weight: 400; font-size: 12px; }
  @media (max-width: 540px) { .calc-grid { grid-template-columns: 1fr; } }
</style>
