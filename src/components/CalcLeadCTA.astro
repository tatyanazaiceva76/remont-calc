---
// Блок CTA "Хотите точную смету?" — ставится сразу под результатом калькулятора.
// Конвертирует информационный трафик (юзер пришёл посчитать) в коммерческий (нужен мастер).
interface Props {
  material?: string; // для подстановки в текст
  source?: string;
}
const { material = 'материал', source = 'calc-cta' } = Astro.props;
// Замени на свой WhatsApp
const waMessage = `Здравствуйте! Только что посчитал ${material} на сайте, хочу узнать про ремонт. Источник: ${source}`;
---
<section class="calc-cta-box">
  <div class="cta-content">
    <h3>📋 Точная смета — бесплатно</h3>
    <p>Калькулятор даёт ориентир. Точную смету по вашей квартире составят мастера — сравните 3-5 предложений и выберите лучшее.</p>
  </div>
  <div class="cta-actions">
       target="_blank" rel="nofollow noopener"
    <a href="https://profi.ru/repair/" target="_blank" rel="nofollow sponsored noopener" class="cta-btn cta-profi" data-source={source}>
      🔍 Найти мастера на Profi.ru
    </a>
  </div>
</section>

<style>
  .calc-cta-box {
    background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
    color: #fff;
    padding: 20px 24px;
    border-radius: 10px;
    margin: 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .cta-content { flex: 1; min-width: 240px; }
  .cta-content h3 { color: #fff; margin: 0 0 6px; font-size: 18px; }
  .cta-content p { color: #fff8e1; margin: 0; font-size: 14px; line-height: 1.5; }
  .cta-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: transform 0.1s;
  }
  .cta-btn:hover { text-decoration: none; transform: translateY(-1px); }
