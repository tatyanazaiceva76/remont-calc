---
import Base from '~/layouts/Base.astro';
---
<Base title="Маленькие кухни (до 6 м²) в Нижний Новгород — от 80k ₽ | Кухни на заказ" description="Эргономика, до потолка, встроенная техника в Нижний Новгород. Бесплатный замер.">
  <h1>Маленькие кухни (до 6 м²) в Нижний Новгород</h1>
  <p style="font-size:17px;background:white;padding:14px;border-left:4px solid #e67e22;border-radius:0 8px 8px 0;">Эргономика, до потолка, встроенная техника. Цена: <strong>от 80k ₽</strong> в Нижний Новгород.</p>

  <section style="background:white;padding:20px;border-radius:10px;margin:20px 0;">
    <h2>📞 Заказать «Маленькие кухни (до 6 м²)» в Нижний Новгород</h2>
    <form id="lf2" style="display:flex;gap:8px;max-width:400px;">
      <input type="tel" name="phone" placeholder="+7 (___) ___-__-__" required minlength="10" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;" />
      <button type="submit" style="padding:12px 20px;background:#e67e22;color:white;border:none;border-radius:8px;font-weight:700;cursor:pointer;">Заказать →</button>
    </form>
    <script is:inline>
      document.getElementById('lf2').onsubmit=function(e){e.preventDefault();fetch('https://www.kalkremont.ru/api/lead',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:e.target.phone.value,host:'nn.kuhni-zakaz-online.ru',niche:'Кухни на заказ',city:'nn',service:'malenkaya',source:'nn.kuhni-zakaz-online.ru/uslugi/malenkaya',url:location.href,page:'/uslugi/malenkaya/'})}).then(function(){e.target.innerHTML='<p style="color:#27ae60;">✅ Заявка принята!</p>';});};
    </script>
  </section>
</Base>
