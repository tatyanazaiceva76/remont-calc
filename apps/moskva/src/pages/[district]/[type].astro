---
import Base from '~/layouts/Base.astro';
import { districts, repairTypes } from '~/data/districts';
import { SITE_CONFIG } from '~/config';
import LeadForm from '~/components/LeadForm.astro';

export async function getStaticPaths() {
  const paths = [];
  for (const d of districts) {
    for (const t of repairTypes) {
      paths.push({ params: { district: d.slug, type: t.key }, props: { district: d, type: t } });
    }
  }
  return paths;
}
const { district, type } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const base = type.pricePerSqM * district.priceMultiplier;
const low = Math.round(base * 0.85);
const high = Math.round(base * 1.3);
const example40 = Math.round(base * 40);
const example60 = Math.round(base * 60);
const example90 = Math.round(base * 90);

const title = `${type.name} в ${district.shortName} (Москва) — цены ${low.toLocaleString('ru-RU')}-${high.toLocaleString('ru-RU')} ₽/м²`;
const description = `${type.name} квартиры в ${district.shortName} округе Москвы. Цена ${low.toLocaleString('ru-RU')}-${high.toLocaleString('ru-RU')} ₽/м². Сроки ${type.durationDays}. Особенности района и расчёт.`;

const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Москва', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: district.shortName, item: `https://${SITE_CONFIG.domain}/${district.slug}/` },
    { '@type': 'ListItem', position: 3, name: type.name, item: url }
  ]
};
const offerSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: `${type.name} в ${district.shortName} округе Москвы`,
  serviceType: type.name,
  areaServed: { '@type': 'AdministrativeArea', name: district.name },
  offers: {
    '@type': 'Offer',
    price: low, priceCurrency: 'RUB',
    description: `${type.name}, цена за м² в ${district.shortName}`
  },
  description, url
};
const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs, offerSchema] };

const faqs = [
  { q: `Сколько стоит ${type.name.toLowerCase()} в ${district.shortName} реально?`,
    a: `Цены на странице — это средние ставки 2026 для типового жилья ${district.shortName}. Финал зависит от площади, состояния квартиры и материалов. Точный расчёт за 5 минут — отправьте заявку через форму.` },
  { q: `Какие гарантии на ${type.name.toLowerCase()}?`,
    a: 'Гарантия 1-2 года на работы. Если что-то треснет/отвалится — приедем и исправим за свой счёт. Гарантия прописана в договоре, не на словах.' },
  { q: `Можно ли разбить оплату на этапы?`,
    a: 'Да. Стандартно: 30% предоплата → оплата после демонтажа → после черновых работ → финал после приёмки. Никаких полных предоплат за весь объём — это защищает обе стороны.' },
  { q: `Сколько по срокам реально займёт ${type.name.toLowerCase()}?`,
    a: `Срок ${type.durationDays}, но точная цифра зависит от площади и состояния квартиры. На студию 25 м² — минимум, на 3-комн 90 м² — больше. После замера дам конкретный график по этапам.` },
  { q: `Кто будет работать на объекте?`,
    a: `Проверенные бригады с опытом 5+ лет именно в ${district.shortName} и соседних районах. Знают локальную специфику жилого фонда, договорённости с управляющими компаниями, особенности доступа к подъезду.` },
  { q: `Включены ли материалы в стоимость?`,
    a: 'Указанная цена — только за работы. Материалы покупаются отдельно (около +50-100% к работам, зависит от уровня). Если нужно "под ключ" с материалами — посмотрите страницу /pod-klyuch/ для этого района.' }
];
const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};
---
<Base title={title} description={description} canonical={url} schema={schema}>
  <nav class="bc">
    <a href="/">Москва</a> ›
    <a href={`/${district.slug}/`}>{district.shortName}</a> ›
    <span>{type.name}</span>
  </nav>
  <h1>{type.name} в {district.shortName} — цены и особенности</h1>
  <p class="muted">{district.name} · базовая ставка {type.pricePerSqM.toLocaleString('ru-RU')} ₽/м² × коэффициент района {district.priceMultiplier.toFixed(2)}</p>

  <div class="price-card">
    <div class="pc-main">
      <div class="pc-label">Цена в {district.shortName}</div>
      <div class="pc-value">{low.toLocaleString('ru-RU')} — {high.toLocaleString('ru-RU')} ₽/м²</div>
      <div class="pc-sub">Срок: {type.durationDays}</div>
    </div>
  </div>

  <p class="lead">{type.description}</p>
  <p>В {district.shortName} округе {type.name.toLowerCase()} имеет свою специфику из-за {district.intro.toLowerCase().includes('премиум') ? 'премиум-аудитории и высоких требований к качеству' : district.intro.toLowerCase().includes('массов') || district.intro.toLowerCase().includes('доступн') ? 'типовой панельной застройки и оптимизации бюджета' : 'смешанной застройки и разных требований'}.</p>

  <h2>Расчёт стоимости на типичные квартиры в {district.shortName}</h2>
  <table class="prices">
    <thead><tr><th>Площадь</th><th>Стоимость работ</th><th>Срок</th></tr></thead>
    <tbody>
      <tr><td>1-комн. 40 м²</td><td><strong>{example40.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
      <tr><td>2-комн. 60 м²</td><td><strong>{example60.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
      <tr><td>3-комн. 90 м²</td><td><strong>{example90.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
    </tbody>
  </table>

  <LeadForm context={`${type.name} в ${district.shortName}`} priceFrom={Math.round(type.pricePerSqM * district.priceMultiplier * 40 * 0.85)} whatsapp={SITE_CONFIG.whatsapp} />
  <p class="muted">Расчёт по средней цене {Math.round(base).toLocaleString('ru-RU')} ₽/м² (только работы, без материалов).</p>

  <h2>Что входит в {type.ruShort.toLowerCase()} в {district.shortName}</h2>
  <ul class="includes">
    {type.includes.map((i) => <li>{i}</li>)}
  </ul>

  <h2>Особенности {type.ruShort.toLowerCase()}а именно в {district.shortName}</h2>
  <ul class="factors">
    {district.uniqueFactors.map((f) => <li>{f}</li>)}
  </ul>

  <h2>Жилой фонд района и его влияние на {type.ruShort.toLowerCase()}</h2>
  <p>{district.housingProfile}</p>
  <p>
    Это значит для {type.name.toLowerCase()}а:
    {type.key === 'cosmetic' && ' меньше штробления, акцент на отделку — обои/краску, пол. Не трогаем коммуникации.'}
    {type.key === 'capital' && ' замена ВСЕХ коммуникаций обязательна — старые трубы и проводка не выдержат современной нагрузки. Это +30-40% к смете против "просто обновить".'}
    {type.key === 'euro' && ' закладывайте 1,3× к базовой смете на импортные материалы. В премиум-сегменте района это норма, мастера сюда привыкли.'}
    {type.key === 'designer' && ' дизайн-проект (50-80 тыс ₽) + авторский надзор (15-20% от сметы) + эксклюзивные материалы — итоговая стоимость может удвоиться против калькулятора.'}
  </p>

  <h2>Метро и логистика</h2>
  <p class="metros">{district.topMetroStations.join(' · ')}</p>

  <h2>Как сэкономить на {type.ruShort.toLowerCase()}е в {district.shortName}</h2>
  <ul>
    <li><strong>Закупка материалов своими силами</strong> — экономия 10-15% против "под ключ" с материалами от подрядчика.</li>
    <li><strong>Сезонность</strong> — зимой (январь-март) скидки до 15% от бригад, нет очередей.</li>
    <li><strong>Дробление этапов</strong> — отделить демонтаж и черновые от чистовых, контролировать по этапам.</li>
    {district.priceMultiplier > 1.1 && <li><strong>В премиум-районе</strong> — берите бригаду с соседнего округа, разница в цене 15-20% за то же качество.</li>}
    {type.key === 'designer' && <li><strong>Гибрид «евро + точечный дизайн»</strong> — сделать евроремонт + 1-2 дизайнерских акцента (камин, стенка), экономия 30-40%.</li>}
  </ul>

  <h2>Чек-лист перед стартом {type.ruShort.toLowerCase()}а в {district.shortName}</h2>
  <ol class="checklist">
    <li>Замер квартиры с учётом фактического метража (часто отличается от БТИ на 1-3 м²)</li>
    {type.key !== 'cosmetic' && <li>Согласование перепланировки (если планируется) — особенно важно в Москве из-за охранных статусов</li>}
    <li>Договор с подрядчиком + смета на материалы + смета на работы (раздельно)</li>
    <li>Договорённость с соседями о шумных работах (часы 9-19 по будням, выходные — без перфоратора)</li>
    {district.priceMultiplier > 1.2 && <li>Согласование разгрузки материалов (платная парковка / ночные часы)</li>}
    <li>Закладка резерва 10-15% сверх сметы на непредвиденное</li>
  </ol>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <h2>❓ Часто спрашивают</h2>
  <div class="faqs">
    {faqs.map((f) => (
      <details class="faq">
        <summary>{f.q}</summary>
        <p>{f.a}</p>
      </details>
    ))}
  </div>

  <h2>Связанные страницы</h2>
  <ul class="related">
    <li><a href={`/${district.slug}/`}>← Все типы ремонта в {district.shortName}</a></li>
    {repairTypes.filter((t) => t.key !== type.key).map((t) => (
      <li><a href={`/${district.slug}/${t.key}/`}>{t.name} в {district.shortName} — от {Math.round(t.pricePerSqM * district.priceMultiplier * 0.85).toLocaleString('ru-RU')} ₽/м²</a></li>
    ))}
  </ul>

  <h2>Другие округа Москвы</h2>
  <ul class="other-d">
    {districts.filter((d) => d.slug !== district.slug).slice(0, 8).map((d) => (
      <li><a href={`/${d.slug}/${type.key}/`}>{type.ruShort} в {d.shortName}</a></li>
    ))}
  </ul>

  <p class="back-cta">
    <a href={`https://www.${SITE_CONFIG.parentDomain}/`}>Калькуляторы материалов</a> ·
    <a href={`https://sovety.${SITE_CONFIG.parentDomain}/`}>Гайды по ремонту</a>
  </p>
</Base>
<style>
.faqs { margin: 12px 0 24px; }
  .faq { background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 8px; margin-bottom: 8px; }
  .faq summary { cursor: pointer; padding: 14px 18px; font-weight: 600; font-size: 15px; list-style: none; color: #1a1a1a; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::before { content: '▸ '; color: #c0392b; font-weight: 700; }
  .faq[open] summary::before { content: '▾ '; }
  .faq p { padding: 0 18px 14px; margin: 0; color: #444; font-size: 14px; line-height: 1.65; }

  .bc { font-size: 13px; color: #777; margin: 0 0 16px; }
  .bc a { color: #555; }
  .muted { color: #888; font-size: 14px; }
  .lead { font-size: 17px; color: #444; }
  .price-card {
    background: linear-gradient(135deg, #fffaf3 0%, #fff7e6 100%);
    border: 2px solid #f5a623; border-radius: 10px;
    padding: 18px 22px; margin: 18px 0;
  }
  .pc-label { font-size: 13px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
  .pc-value { font-size: 26px; font-weight: 700; color: #c0392b; margin: 4px 0; }
  .pc-sub { font-size: 14px; color: #555; }
  .prices { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 14px; }
  .prices th, .prices td { padding: 10px 12px; border: 1px solid #e6e8eb; text-align: left; }
  .prices th { background: #fff7e6; font-weight: 700; }
  .includes, .factors, .checklist { padding-left: 22px; }
  .includes li, .factors li, .checklist li { margin-bottom: 6px; }
  .related, .other-d { list-style: none; padding: 0; }
  .related li { padding: 8px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; margin-bottom: 6px; font-size: 14px; }
  .other-d { display: flex; flex-wrap: wrap; gap: 8px; }
  .other-d a { display: inline-block; padding: 6px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 16px; font-size: 13px; color: #1a1a1a; }
  .metros { padding: 12px 14px; background: #fffaf3; border: 1px solid #f5d3a3; border-radius: 6px; font-size: 14px; }
  .back-cta { margin-top: 32px; font-size: 14px; color: #888; text-align: center; }
</style>
