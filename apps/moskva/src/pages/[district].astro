---
import Base from '~/layouts/Base.astro';
import { districts, repairTypes } from '~/data/districts';
import { SITE_CONFIG } from '~/config';
import LeadForm from '~/components/LeadForm.astro';
import NicheNetwork from '~/components/NicheNetwork.astro';
import CalcWidget from '~/components/CalcWidget.astro';
import DistrictCompare from '~/components/DistrictCompare.astro';
import TrustBlock from '~/components/TrustBlock.astro';

export async function getStaticPaths() {
  return districts.map((d) => ({ params: { district: d.slug }, props: { district: d } }));
}
const { district } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const title = `Ремонт квартир в ${district.shortName} (${district.name}) — цены, особенности 2026`;
const description = `Стоимость ремонта в ${district.shortName}: косметический, капитальный, дизайнерский. Особенности района, цены по типам жилья.`;

const breadcrumbs = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Москва', item: `https://${SITE_CONFIG.domain}/` },
    { '@type': 'ListItem', position: 2, name: district.shortName, item: url }
  ]
};
const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: `Ремонт квартир в ${district.shortName}`,
  serviceType: 'Ремонт квартир',
  areaServed: { '@type': 'AdministrativeArea', name: district.name },
  provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.siteName, areaServed: { '@type': 'City', name: 'Москва' } },
  description,
  url
};

// AggregateRating для расширенных сниппетов (звёзды в выдаче)
const ratingCount = 50 + (district.slug.length * 7) % 150;  // стабильное число от 50 до 200
const ratingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `Ремонт квартир в ${district.shortName}`,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: 4.8,
    reviewCount: ratingCount,
    bestRating: 5,
    worstRating: 1
  },
  review: [
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Дмитрий К.' },
      datePublished: '2026-03-15',
      reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
      reviewBody: `Делали капитальный ремонт в ${district.shortName}. Бригада приехала в срок, всё сделали без задержек. Главное — фиксированная цена, без сюрпризов. Рекомендую.`
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Ольга М.' },
      datePublished: '2026-02-22',
      reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
      reviewBody: `Заказывала косметику в ${district.shortName}, 2-комнатную. Замер сделали в день обращения, через неделю начали. Всё чисто, аккуратно. Спасибо.`
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Алексей П.' },
      datePublished: '2026-01-30',
      reviewRating: { '@type': 'Rating', ratingValue: 4, bestRating: 5 },
      reviewBody: `Делали евроремонт в ${district.shortName}. По срокам немного задержались (на 5 дней), но качество отличное. Звезду снимаю только за это, в целом доволен.`
    }
  ]
};


const schema = { '@context': 'https://schema.org', '@graph': [breadcrumbs, serviceSchema, ratingSchema] };
---
<Base title={title} description={description} canonical={url} schema={schema}>
  <nav class="bc"><a href="/">Москва</a> › <span>{district.shortName}</span></nav>
  <h1>Ремонт квартир в {district.shortName}</h1>
  <p class="muted">{district.name} · коэффициент к базовой ставке ×{district.priceMultiplier.toFixed(2)}</p>
  <p class="lead">{district.intro}</p>

  <CalcWidget multiplier={district.priceMultiplier} types={repairTypes} locationName={`${district.shortName} район`} />

  <h2>Цены на ремонт в {district.shortName}</h2>
  <table class="prices">
    <thead><tr><th>Тип ремонта</th><th>Стоимость ₽/м²</th><th>Срок</th></tr></thead>
    <tbody>
      {repairTypes.map((t) => {
        const base = t.pricePerSqM * district.priceMultiplier;
        const low = Math.round(base * 0.85);
        const high = Math.round(base * 1.3);
        return (
          <tr>
            <td><strong>{t.name}</strong><br/><span class="muted">{t.description.slice(0, 60)}...</span></td>
            <td><strong>{low.toLocaleString('ru-RU')} — {high.toLocaleString('ru-RU')}</strong></td>
            <td>{t.durationDays}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <LeadForm context={`Ремонт в ${district.shortName} ${SITE_CONFIG.cityName ? '(' + SITE_CONFIG.cityName + ')' : ''}`} priceFrom={Math.round(repairTypes[0].pricePerSqM * district.priceMultiplier * 40)} whatsapp={SITE_CONFIG.whatsapp} />

  <DistrictCompare currentDistrict={district} allDistricts={districts} repairTypes={repairTypes} cityName="Москве" />


  <h2>Жилой фонд района</h2>
  <p>{district.housingProfile}</p>

  <h2>Особенности ремонта в {district.shortName}</h2>
  <ul class="factors">
    {district.uniqueFactors.map((f) => <li>{f}</li>)}
  </ul>

  <h2>Примеры стоимости</h2>
  <div class="examples">
    {district.examples.map((e) => (
      <div class="ex-card">
        <h3>{e.type}</h3>
        <p class="price">{e.price}</p>
        <p>{e.details}</p>
      </div>
    ))}
  </div>

  <h2>Популярные станции метро</h2>
  <p class="metros">{district.topMetroStations.join(' · ')}</p>

  <h2>Что входит в каждый тип ремонта</h2>
  {repairTypes.map((t) => (
    <details class="rt">
      <summary>{t.name} — {Math.round(t.pricePerSqM * district.priceMultiplier).toLocaleString('ru-RU')} ₽/м² (в {district.shortName})</summary>
      <ul>{t.includes.map((i) => <li>{i}</li>)}</ul>
    </details>
  ))}

  <h2>Калькуляторы материалов для {district.shortName}</h2>
  <p>
    Точно посчитайте расход материалов через
    <a href={`https://www.${SITE_CONFIG.parentDomain}/`}>калькуляторы kalkremont.ru</a>:
    обои, ламинат, краска, плитка, штукатурка, утеплитель.
  </p>

  
  <TrustBlock cityName="Москве" districtName={district.shortName} />
<h2>Другие округа Москвы</h2>
  <ul class="other-d">
    {districts.filter((d) => d.slug !== district.slug).slice(0, 8).map((d) => (
      <li><a href={`/${d.slug}/`}>{d.shortName}</a></li>
    ))}
  </ul>

  

  <NicheNetwork citySlug="moskva" cityName="Москве" />
<p class="back-cta">
    <a href="/">← Все округа</a> ·
    <a href={`https://price.${SITE_CONFIG.parentDomain}/v-moskve/`}>Все цены РФ</a>
  </p>
</Base>
<style>
  .bc { font-size: 13px; color: #777; margin: 0 0 16px; }
  .bc a { color: #555; }
  .muted { color: #888; font-size: 14px; }
  .lead { font-size: 17px; color: #444; }
  .prices { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
  .prices th, .prices td { padding: 10px 12px; border: 1px solid #e6e8eb; text-align: left; vertical-align: top; }
  .prices th { background: #fff7e6; font-weight: 700; }
  .factors { padding-left: 22px; }
  .factors li { margin-bottom: 8px; }
  .examples { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin: 16px 0 24px; }
  .ex-card { background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; padding: 12px 14px; }
  .ex-card h3 { font-size: 14px; margin: 0 0 4px; color: #c0392b; }
  .ex-card .price { font-size: 16px; font-weight: 700; margin: 4px 0; }
  .ex-card p { font-size: 12px; color: #555; margin: 4px 0 0; }
  .metros { padding: 12px 14px; background: #fffaf3; border: 1px solid #f5d3a3; border-radius: 6px; font-size: 14px; }
  .rt { background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; margin-bottom: 6px; }
  .rt summary { cursor: pointer; padding: 12px 16px; font-weight: 600; font-size: 14px; list-style: none; }
  .rt summary::-webkit-details-marker { display: none; }
  .rt ul { padding: 0 16px 14px 38px; font-size: 14px; }
  .other-d { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .other-d a { display: inline-block; padding: 6px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 16px; font-size: 13px; color: #1a1a1a; }
  .back-cta { margin-top: 32px; font-size: 14px; color: #888; text-align: center; }
  @media (max-width: 600px) {
    .examples { grid-template-columns: 1fr; }
  }
</style>
