---
import { SITE_CONFIG } from '~/config';
interface Props { title: string; description: string; canonical?: string; schema?: object; }
const { title, description, canonical, schema } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="yandex-verification" content="460ea36bfc80a84e" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://www.kalkremont.ru/og/main.svg" />
    <link rel="preconnect" href="https://mc.yandex.ru" />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <script is:inline define:vars={{ id: SITE_CONFIG.metrikaId }}>
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
      ym(id, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
    </script>
  </head>
  <body>
    <header class="hdr">
      <div class="ctr">
        <a href="/" class="logo">🔧 Калькремонт · {SITE_CONFIG.domain}</a>
        <nav>
          <a href="/">Главная</a>
          <a href={`https://www.${SITE_CONFIG.parentDomain}/`}>Все услуги</a>
          <a href={`https://www.${SITE_CONFIG.parentDomain}/elektromontazh/`}>На основном сайте</a>
        </nav>
      </div>
    </header>
    <main class="ctr"><slot /></main>
    <footer class="ftr">
      <div class="ctr"><p>© {new Date().getFullYear()} {SITE_CONFIG.domain}. Часть проекта <a href={`https://www.${SITE_CONFIG.parentDomain}/`}>{SITE_CONFIG.parentDomain}</a>.</p></div>
    </footer>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; font-size: 16px; line-height: 1.65; color: #1a1a1a; background: #fff; }
      h1, h2, h3 { line-height: 1.25; margin: 0 0 16px; }
      h1 { font-size: 30px; } h2 { font-size: 22px; margin-top: 36px; } h3 { font-size: 18px; margin-top: 24px; }
      p { margin: 0 0 14px; }
      a { color: #0a5cce; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .ctr { max-width: 900px; margin: 0 auto; padding: 0 16px; }
      .hdr { background: linear-gradient(135deg, #0a5cce 0%, #053a83 100%); color: #fff; padding: 14px 0; }
      .hdr .ctr { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .logo { font-weight: 700; color: #fff; font-size: 16px; }
      .hdr nav { display: flex; gap: 18px; font-size: 14px; flex-wrap: wrap; }
      .hdr nav a { color: rgba(255,255,255,0.9); }
      main { padding: 24px 16px 48px; }
      .ftr { background: #f7f8fa; border-top: 1px solid #e6e8eb; padding: 20px 0; font-size: 13px; color: #666; }
    </style>
  </body>
</html>
