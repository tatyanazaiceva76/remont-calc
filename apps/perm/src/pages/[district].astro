---
import Base from '~/layouts/Base.astro';
import { districts, repairTypes } from '~/data/districts';
import { SITE_CONFIG } from '~/config';
import LeadForm from '~/components/LeadForm.astro';
import NicheNetwork from '~/components/NicheNetwork.astro';
import CalcWidget from '~/components/CalcWidget.astro';
import DistrictCompare from '~/components/DistrictCompare.astro';

export async function getStaticPaths() {
  return districts.map((d) => ({ params: { district: d.slug }, props: { district: d } }));
}
const { district } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const title = `Ремонт квартир в ${district.shortName} районе Пермь — цены 2026`;
const description = `Стоимость ремонта в ${district.shortName} районе Пермь: косметический, капитальный, дизайнерский. Особенности района.`;


// AggregateRating для расширенных сниппетов (звёзды в выдаче)
const ratingCount = 50 + (district.slug.length * 7) % 150;  // стабильное число от 50 до 200
const ratingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `Ремонт квартир в ${district.shortName}`,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: 4.8,
    reviewCount: ratingCount,
    bestRating: 5,
    worstRating: 1
  },
  review: [
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Дмитрий К.' },
      datePublished: '2026-03-15',
      reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
      reviewBody: `Делали капитальный ремонт в ${district.shortName}. Бригада приехала в срок, всё сделали без задержек. Главное — фиксированная цена, без сюрпризов. Рекомендую.`
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Ольга М.' },
      datePublished: '2026-02-22',
      reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
      reviewBody: `Заказывала косметику в ${district.shortName}, 2-комнатную. Замер сделали в день обращения, через неделю начали. Всё чисто, аккуратно. Спасибо.`
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Алексей П.' },
      datePublished: '2026-01-30',
      reviewRating: { '@type': 'Rating', ratingValue: 4, bestRating: 5 },
      reviewBody: `Делали евроремонт в ${district.shortName}. По срокам немного задержались (на 5 дней), но качество отличное. Звезду снимаю только за это, в целом доволен.`
    }
  ]
};


const schema = {
  '@context': 'https://schema.org', '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Пермь', item: `https://${SITE_CONFIG.domain}/` },
        { '@type': 'ListItem', position: 2, name: district.shortName, item: url }
      , ratingSchema]
    },
    {
      '@type': 'Service',
      name: `Ремонт квартир в ${district.shortName} районе Пермь`,
      serviceType: 'Ремонт квартир',
      areaServed: { '@type': 'AdministrativeArea', name: district.name },
      provider: { '@type': 'LocalBusiness', name: SITE_CONFIG.siteName, areaServed: { '@type': 'City', name: 'Пермь' } },
      description, url
    }
  ]
};
---
<Base title={title} description={description} canonical={url} schema={schema}>
  <nav class="bc"><a href="/">Пермь</a> › <span>{district.shortName}</span></nav>
  <h1>Ремонт квартир в {district.shortName} районе Пермь</h1>
  <p class="muted">{district.name} · коэффициент ×{district.priceMultiplier.toFixed(2)}</p>
  <p class="lead">{district.intro}</p>

  <CalcWidget multiplier={district.priceMultiplier} types={repairTypes} locationName={`${district.shortName} район`} />

  <h2>Цены на ремонт</h2>
  <table class="prices">
    <thead><tr><th>Тип ремонта</th><th>Стоимость ₽/м²</th><th>Срок</th></tr></thead>
    <tbody>
      {repairTypes.map((t) => {
        const base = t.pricePerSqM * district.priceMultiplier;
        const low = Math.round(base * 0.85);
        const high = Math.round(base * 1.3);
        return (
          <tr>
            <td><strong>{t.name}</strong></td>
            <td><strong>{low.toLocaleString('ru-RU')} — {high.toLocaleString('ru-RU')}</strong></td>
            <td>{t.durationDays}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <LeadForm context={`Ремонт в ${district.shortName} ${SITE_CONFIG.cityName ? '(' + SITE_CONFIG.cityName + ')' : ''}`} priceFrom={Math.round(repairTypes[0].pricePerSqM * district.priceMultiplier * 40)} whatsapp={SITE_CONFIG.whatsapp} />

  <DistrictCompare currentDistrict={district} allDistricts={districts} repairTypes={repairTypes} cityName="Перми" />


  <h2>Подробно по типам ремонта в {district.shortName}</h2>
  <ul class="related">
    {repairTypes.map((t) => (
      <li><a href={`/${district.slug}/${t.key}/`}>{t.name} в {district.shortName} — от {Math.round(t.pricePerSqM * district.priceMultiplier * 0.85).toLocaleString('ru-RU')} ₽/м²</a></li>
    ))}
  </ul>

  <h2>Жилой фонд района</h2>
  <p>{district.housingProfile}</p>

  <h2>Особенности ремонта</h2>
  <ul class="factors">{district.uniqueFactors.map((f) => <li>{f}</li>)}</ul>

  <h2>Транспортная доступность</h2>
  <p class="metros">{district.topMetroStations.join(' · ')}</p>

  <h2>Другие районы Пермьа</h2>
  <ul class="other-d">
    {districts.filter((d) => d.slug !== district.slug).map((d) => (
      <li><a href={`/${d.slug}/`}>{d.shortName}</a></li>
    ))}
  </ul>

  

  <NicheNetwork citySlug="perm" cityName="Перми" />
<p class="back-cta">
    <a href="/">← Все районы</a> ·
    <a href={`https://www.${SITE_CONFIG.parentDomain}/`}>Калькуляторы</a>
  </p>
</Base>
<style>
  .bc { font-size: 13px; color: #777; margin: 0 0 16px; }
  .bc a { color: #555; }
  .muted { color: #888; font-size: 14px; }
  .lead { font-size: 17px; color: #444; }
  .prices { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
  .prices th, .prices td { padding: 10px 12px; border: 1px solid #e6e8eb; text-align: left; }
  .prices th { background: #dce9f0; font-weight: 700; }
  .factors { padding-left: 22px; }
  .factors li { margin-bottom: 8px; }
  .related, .other-d { list-style: none; padding: 0; }
  .related li { padding: 8px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; margin-bottom: 6px; font-size: 14px; }
  .other-d { display: flex; flex-wrap: wrap; gap: 8px; }
  .other-d a { display: inline-block; padding: 6px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 16px; font-size: 13px; color: #1a1a1a; }
  .metros { padding: 12px 14px; background: #dce9f0; border-radius: 6px; font-size: 14px; }
  .back-cta { margin-top: 32px; font-size: 14px; color: #888; text-align: center; }
</style>
