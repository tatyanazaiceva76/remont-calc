---
import Base from '~/layouts/Base.astro';
const rooms = [{"num":1,"name":"студия","emoji":"🏠","area":25},{"num":2,"name":"1-комнатная","emoji":"🏘","area":35},{"num":3,"name":"2-комнатная","emoji":"🏘","area":55},{"num":4,"name":"3-комнатная","emoji":"🏢","area":80},{"num":5,"name":"большая","emoji":"🏛","area":120}];
const cities = [{"slug":"moskva","name":"Подмосковье","nameNom":"Подмосковье","priceMult":1.4},{"slug":"spb","name":"Ленобласти","nameNom":"Ленобласть","priceMult":1.3},{"slug":"ekb","name":"Свердловской области","nameNom":"Свердловская обл.","priceMult":1},{"slug":"kzn","name":"Татарстане","nameNom":"Татарстан","priceMult":1},{"slug":"nsk","name":"Новосибирской области","nameNom":"Новосибирская обл.","priceMult":0.95},{"slug":"krd","name":"Краснодарском крае","nameNom":"Краснодарский край","priceMult":1.1}];

export function getStaticPaths() {
  const rooms = [{"num":1,"name":"студия","emoji":"🏠","area":25},{"num":2,"name":"1-комнатная","emoji":"🏘","area":35},{"num":3,"name":"2-комнатная","emoji":"🏘","area":55},{"num":4,"name":"3-комнатная","emoji":"🏢","area":80},{"num":5,"name":"большая","emoji":"🏛","area":120}];
  return rooms.map((r) => ({ params: { rooms: String(r.num) }, props: { room: r } }));
}

const { room } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;
---
<Base title={`Загородные дома ${room.name} квартиры`} description={'Загородные дома ' + room.name + ' (~' + room.area + ' м²) — выберите город.'} canonical={url}>
  <nav class="bc"><a href="/">Загородные дома</a> › <a href="/komnaty/">Комнаты</a> › <span>{room.name}</span></nav>
  <h1>{room.emoji} Загородные дома {room.name} квартиры</h1>
  <p class="lead">Средняя площадь: {room.area} м². Выберите город для расчёта.</p>

  <section>
    <h2>🏙 Выберите город</h2>
    <div class="grid">
      {cities.map((c) => (
        <a href={`/komnaty/${room.num}/v-${c.slug}/`} class="c">
          <strong>{c.nameNom}</strong>
        </a>
      ))}
    </div>
  </section>
</Base>
<style>
  .bc{font-size:13px;color:#888;}
  .lead{padding:16px;background:white;border-left:4px solid #27ae60;}
  .grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;}
  .c{padding:10px;background:white;border:1px solid #e6e8eb;border-radius:6px;text-decoration:none;text-align:center;}
  .c:hover{border-color:#27ae60;}
  .c strong{color:#27ae60;font-size:13px;}
  @media (max-width:700px){.grid{grid-template-columns:1fr 1fr 1fr;}}
</style>
