---
import Base from '~/layouts/Base.astro';
---
<Base title="Кирпичные дома в Уфа — от 55k ₽/м² | Загородные дома" description="Срок 8-12 месяцев, премиум в Уфа. Бесплатный замер.">
  <h1>Кирпичные дома в Уфа</h1>
  <p style="font-size:17px;background:white;padding:14px;border-left:4px solid #27ae60;border-radius:0 8px 8px 0;">Срок 8-12 месяцев, премиум. Цена: <strong>от 55k ₽/м²</strong> в Уфа.</p>

  <section style="background:white;padding:20px;border-radius:10px;margin:20px 0;">
    <h2>📞 Заказать «Кирпичные дома» в Уфа</h2>
    <form id="lf2" style="display:flex;gap:8px;max-width:400px;">
      <input type="tel" name="phone" placeholder="+7 (___) ___-__-__" required minlength="10" style="flex:1;padding:12px;border:2px solid #ddd;border-radius:8px;" />
      <button type="submit" style="padding:12px 20px;background:#27ae60;color:white;border:none;border-radius:8px;font-weight:700;cursor:pointer;">Заказать →</button>
    </form>
    <script is:inline>
      document.getElementById('lf2').onsubmit=function(e){e.preventDefault();fetch('https://www.kalkremont.ru/api/lead',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:e.target.phone.value,host:'ufa.dom-stroy-online.ru',niche:'Загородные дома',city:'ufa',service:'kirpich',source:'ufa.dom-stroy-online.ru/uslugi/kirpich',url:location.href,page:'/uslugi/kirpich/'})}).then(function(){e.target.innerHTML='<p style="color:#27ae60;">✅ Заявка принята!</p>';});};
    </script>
  </section>
</Base>
