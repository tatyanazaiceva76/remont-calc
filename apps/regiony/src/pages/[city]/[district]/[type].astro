---
import Base from '~/layouts/Base.astro';
import { cities } from '~/data/all-cities';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  const paths = [];
  for (const c of cities) {
    for (const d of c.districts) {
      for (const t of c.repairTypes) {
        paths.push({ params: { city: c.slug, district: d.slug, type: t.key }, props: { city: c, district: d, type: t } });
      }
    }
  }
  return paths;
}
const { city, district, type } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const base = type.pricePerSqM * district.priceMultiplier;
const low = Math.round(base * 0.85);
const high = Math.round(base * 1.3);
const example40 = Math.round(base * 40);
const example60 = Math.round(base * 60);
const example90 = Math.round(base * 90);

const title = `${type.name} в ${district.shortName} районе ${city.cityNameGen} — ${low.toLocaleString('ru-RU')}-${high.toLocaleString('ru-RU')} ₽/м²`;
const description = `${type.name} в ${district.shortName} районе ${city.cityNameGen}. Цена ${low.toLocaleString('ru-RU')}-${high.toLocaleString('ru-RU')} ₽/м². Сроки ${type.durationDays}.`;

const schema = {
  '@context': 'https://schema.org', '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Регионы', item: `https://${SITE_CONFIG.domain}/` },
        { '@type': 'ListItem', position: 2, name: city.cityName, item: `https://${SITE_CONFIG.domain}/${city.slug}/` },
        { '@type': 'ListItem', position: 3, name: district.shortName, item: `https://${SITE_CONFIG.domain}/${city.slug}/${district.slug}/` },
        { '@type': 'ListItem', position: 4, name: type.name, item: url }
      ]
    },
    {
      '@type': 'Service',
      name: `${type.name} в ${district.shortName} районе ${city.cityNameGen}`,
      serviceType: type.name,
      areaServed: { '@type': 'AdministrativeArea', name: district.name },
      offers: { '@type': 'Offer', price: low, priceCurrency: 'RUB' },
      description, url
    }
  ]
};
---
<Base title={title} description={description} canonical={url} schema={schema}
      cityName={city.cityName} geoRegion={city.geo.regionCode} geoLat={city.geo.lat} geoLon={city.geo.lon}>
  <nav class="bc">
    <a href="/">Регионы</a> ›
    <a href={`/${city.slug}/`}>{city.cityName}</a> ›
    <a href={`/${city.slug}/${district.slug}/`}>{district.shortName}</a> ›
    <span>{type.name}</span>
  </nav>
  <h1>{type.name} в {district.shortName} районе {city.cityNameGen}</h1>
  <p class="muted">{district.name} · база {type.pricePerSqM.toLocaleString('ru-RU')} ₽/м² × {district.priceMultiplier.toFixed(2)}</p>

  <div class="price-card">
    <div class="pc-label">Цена в {district.shortName}</div>
    <div class="pc-value">{low.toLocaleString('ru-RU')} — {high.toLocaleString('ru-RU')} ₽/м²</div>
    <div class="pc-sub">Срок: {type.durationDays}</div>
  </div>

  <p class="lead">{type.description}</p>

  <h2>Расчёт на типичные квартиры</h2>
  <table class="prices">
    <thead><tr><th>Площадь</th><th>Стоимость работ</th><th>Срок</th></tr></thead>
    <tbody>
      <tr><td>1-комн. 40 м²</td><td><strong>{example40.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
      <tr><td>2-комн. 60 м²</td><td><strong>{example60.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
      <tr><td>3-комн. 90 м²</td><td><strong>{example90.toLocaleString('ru-RU')} ₽</strong></td><td>{type.durationDays}</td></tr>
    </tbody>
  </table>

  <h2>Что входит</h2>
  <ul class="includes">{type.includes.map((i) => <li>{i}</li>)}</ul>

  <h2>Особенности района {district.shortName}</h2>
  <ul class="factors">{district.uniqueFactors.map((f) => <li>{f}</li>)}</ul>

  <h2>Жилой фонд района</h2>
  <p>{district.housingProfile}</p>

  <h2>Связанные страницы</h2>
  <ul class="related">
    <li><a href={`/${city.slug}/${district.slug}/`}>← Все типы ремонта в {district.shortName}</a></li>
    {city.repairTypes.filter((t) => t.key !== type.key).map((t) => (
      <li><a href={`/${city.slug}/${district.slug}/${t.key}/`}>{t.name} в {district.shortName} — от {Math.round(t.pricePerSqM * district.priceMultiplier * 0.85).toLocaleString('ru-RU')} ₽/м²</a></li>
    ))}
  </ul>

  <h2>Этот тип в других районах {city.cityNameGen}</h2>
  <ul class="other-d">
    {city.districts.filter((d) => d.slug !== district.slug).map((d) => (
      <li><a href={`/${city.slug}/${d.slug}/${type.key}/`}>{type.ruShort} в {d.shortName}</a></li>
    ))}
  </ul>

  <p class="back-cta"><a href={`https://www.${SITE_CONFIG.parentDomain}/`}>Калькуляторы</a> · <a href={`https://sovety.${SITE_CONFIG.parentDomain}/`}>Гайды</a></p>
</Base>
<style>
  .bc { font-size: 13px; color: #777; margin: 0 0 16px; } .bc a { color: #555; }
  .muted { color: #888; font-size: 14px; } .lead { font-size: 17px; color: #444; }
  .price-card { background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%); border: 2px solid #6b3aa0; border-radius: 10px; padding: 18px 22px; margin: 18px 0; }
  .pc-label { font-size: 13px; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
  .pc-value { font-size: 26px; font-weight: 700; color: #6b3aa0; margin: 4px 0; }
  .pc-sub { font-size: 14px; color: #555; }
  .prices { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 14px; }
  .prices th, .prices td { padding: 10px 12px; border: 1px solid #e6e8eb; text-align: left; }
  .prices th { background: #f3e8ff; font-weight: 700; }
  .includes, .factors { padding-left: 22px; }
  .includes li, .factors li { margin-bottom: 6px; }
  .related, .other-d { list-style: none; padding: 0; }
  .related li { padding: 8px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; margin-bottom: 6px; font-size: 14px; }
  .other-d { display: flex; flex-wrap: wrap; gap: 8px; }
  .other-d a { display: inline-block; padding: 6px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 16px; font-size: 13px; color: #1a1a1a; }
  .back-cta { margin-top: 32px; font-size: 14px; color: #888; text-align: center; }
</style>
