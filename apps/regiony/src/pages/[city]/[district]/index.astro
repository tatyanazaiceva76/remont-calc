---
import Base from '~/layouts/Base.astro';
import { cities } from '~/data/all-cities';
import { SITE_CONFIG } from '~/config';

export async function getStaticPaths() {
  const paths = [];
  for (const c of cities) {
    for (const d of c.districts) {
      paths.push({ params: { city: c.slug, district: d.slug }, props: { city: c, district: d } });
    }
  }
  return paths;
}
const { city, district } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site).href;

const title = `Ремонт квартир в ${district.shortName} районе ${city.cityNameGen} — цены 2026`;
const description = `Стоимость ремонта в ${district.shortName} районе ${city.cityNameGen}: косметический, капитальный, дизайнерский.`;

const schema = {
  '@context': 'https://schema.org', '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Регионы', item: `https://${SITE_CONFIG.domain}/` },
        { '@type': 'ListItem', position: 2, name: city.cityName, item: `https://${SITE_CONFIG.domain}/${city.slug}/` },
        { '@type': 'ListItem', position: 3, name: district.shortName, item: url }
      ]
    },
    {
      '@type': 'Service',
      name: `Ремонт квартир в ${district.shortName} районе ${city.cityNameGen}`,
      serviceType: 'Ремонт квартир',
      areaServed: { '@type': 'AdministrativeArea', name: district.name },
      provider: { '@type': 'LocalBusiness', name: `Ремонт в ${city.cityName}`, areaServed: { '@type': 'City', name: city.cityName } },
      description, url
    }
  ]
};
---
<Base title={title} description={description} canonical={url} schema={schema}
      cityName={city.cityName} geoRegion={city.geo.regionCode} geoLat={city.geo.lat} geoLon={city.geo.lon}>
  <nav class="bc"><a href="/">Регионы</a> › <a href={`/${city.slug}/`}>{city.cityName}</a> › <span>{district.shortName}</span></nav>
  <h1>Ремонт квартир в {district.shortName} районе {city.cityNameGen}</h1>
  <p class="muted">{district.name} · коэффициент ×{district.priceMultiplier.toFixed(2)}</p>
  <p class="lead">{district.intro}</p>

  <h2>Цены на ремонт</h2>
  <table class="prices">
    <thead><tr><th>Тип ремонта</th><th>Стоимость ₽/м²</th><th>Срок</th></tr></thead>
    <tbody>
      {city.repairTypes.map((t) => {
        const base = t.pricePerSqM * district.priceMultiplier;
        const low = Math.round(base * 0.85);
        const high = Math.round(base * 1.3);
        return (
          <tr>
            <td><strong>{t.name}</strong></td>
            <td><strong>{low.toLocaleString('ru-RU')} — {high.toLocaleString('ru-RU')}</strong></td>
            <td>{t.durationDays}</td>
          </tr>
        );
      })}
    </tbody>
  </table>

  <h2>Подробно по типам ремонта в {district.shortName}</h2>
  <ul class="related">
    {city.repairTypes.map((t) => (
      <li><a href={`/${city.slug}/${district.slug}/${t.key}/`}>{t.name} в {district.shortName} — от {Math.round(t.pricePerSqM * district.priceMultiplier * 0.85).toLocaleString('ru-RU')} ₽/м²</a></li>
    ))}
  </ul>

  <h2>Жилой фонд района</h2>
  <p>{district.housingProfile}</p>

  <h2>Особенности ремонта</h2>
  <ul class="factors">{district.uniqueFactors.map((f) => <li>{f}</li>)}</ul>

  <h2>Транспортная доступность</h2>
  <p class="metros">{district.topMetroStations.join(' · ')}</p>

  <h2>Другие районы {city.cityNameGen}</h2>
  <ul class="other-d">
    {city.districts.filter((d) => d.slug !== district.slug).map((d) => (
      <li><a href={`/${city.slug}/${d.slug}/`}>{d.shortName}</a></li>
    ))}
  </ul>

  <p class="back-cta"><a href={`/${city.slug}/`}>← Все районы {city.cityNameGen}</a></p>
</Base>
<style>
  .bc { font-size: 13px; color: #777; margin: 0 0 16px; } .bc a { color: #555; }
  .muted { color: #888; font-size: 14px; } .lead { font-size: 17px; color: #444; }
  .prices { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
  .prices th, .prices td { padding: 10px 12px; border: 1px solid #e6e8eb; text-align: left; }
  .prices th { background: #f3e8ff; font-weight: 700; }
  .factors { padding-left: 22px; } .factors li { margin-bottom: 8px; }
  .related, .other-d { list-style: none; padding: 0; }
  .related li { padding: 8px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 6px; margin-bottom: 6px; font-size: 14px; }
  .other-d { display: flex; flex-wrap: wrap; gap: 8px; }
  .other-d a { display: inline-block; padding: 6px 12px; background: #f7f8fa; border: 1px solid #e6e8eb; border-radius: 16px; font-size: 13px; color: #1a1a1a; }
  .metros { padding: 12px 14px; background: #f3e8ff; border-radius: 6px; font-size: 14px; }
  .back-cta { margin-top: 32px; font-size: 14px; color: #888; text-align: center; }
</style>
